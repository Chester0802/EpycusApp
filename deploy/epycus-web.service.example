[Unit]
Description=Epycus Web Application
After=network.target mariadb.service

[Service]
Type=notify
User=www-data
Group=www-data
WorkingDirectory=/var/www/epycus-web
ExecStart=/usr/bin/dotnet /var/www/epycus-web/EpycusApp.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=epycus-web
TimeoutStopSec=90

# Variables de entorno — reemplazar con valores reales en producción
# NO commiter este archivo con credenciales reales
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://localhost:5000
Environment=DisableHttpsRedirect=true
Environment=ConnectionStrings__ConexionPrincipal=Server=localhost;Port=3306;Database=epycus_db;User=epicus_user;Password=CHANGE_ME
Environment=MySql__ServerVersion=11.8.6-mariadb
Environment=Jwt__Clave=CHANGE_ME_32_CHAR_MIN_SECRET_KEY
Environment=Jwt__Emisor=EpycusWeb
Environment=Jwt__Audiencia=EpycusUsuarios
Environment=Jwt__ExpiracionMinutos=60
Environment=Jwt__ExpiracionRefreshDias=7
Environment=Google__ClientId=CHANGE_ME
Environment=Google__ClientSecret=CHANGE_ME
Environment=Correo__Servidor=smtp.gmail.com
Environment=Correo__Puerto=587
Environment=Correo__Usuario=CHANGE_ME
Environment=Correo__Contrasena=CHANGE_ME
Environment=Correo__NombreRemitente=Epycus App
Environment=App__UrlBase=http://app.epycus.es
Environment=Gemini__ApiKey=CHANGE_ME
Environment=Gemini__Modelo=gemini-2.5-flash-lite
Environment=Cors__OrigenesPermitidos__0=http://app.epycus.es
Environment=Cors__OrigenesPermitidos__1=https://app.epycus.es

[Install]
WantedBy=multi-user.target
