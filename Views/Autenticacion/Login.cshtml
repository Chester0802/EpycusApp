@model EpycusApp.ViewModels.Autenticacion.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_LayoutAuth";
}

<div class="ep-card ep-card-neon p-4 position-relative overflow-hidden">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center mb-3 auth-icon-box" style="width: 64px; height: 64px; border-radius: 1rem; background: var(--ep-superficie-2);">
            <img src="~/img/logo.webp" alt="Epycus" style="width: 40px; height: 40px; object-fit: contain;" onerror="this.style.display='none'" />
        </div>
        <h2 class="fw-bold mb-1">Bienvenido a Epycus</h2>
        <p class="text-muted small">Tu viaje hacia la excelencia profesional comienza aquí</p>
    </div>

    <form asp-action="Login" method="post" class="position-relative">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3 py-2 px-3 mb-4 border-0 small" role="alert"></div>

        <div class="mb-4">
            <label asp-for="CorreoElectronico" class="form-label small fw-semibold text-muted mb-2"></label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 text-muted ps-3">
                    <i class="bi bi-envelope"></i>
                </span>
                <input asp-for="CorreoElectronico" class="form-control border-start-0 ps-0 bg-transparent ep-input" placeholder="tucorreo@ejemplo.com" />
            </div>
            <span asp-validation-for="CorreoElectronico" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <label asp-for="Contrasena" class="form-label small fw-semibold text-muted mb-0"></label>
                <a asp-action="RecuperarContrasena" class="small text-decoration-none text-primary fw-medium">¿Olvidaste tu contraseña?</a>
            </div>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 text-muted ps-3">
                    <i class="bi bi-lock"></i>
                </span>
                <input asp-for="Contrasena" class="form-control border-start-0 ps-0 bg-transparent ep-input" placeholder="••••••••" />
            </div>
            <span asp-validation-for="Contrasena" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-4 form-check">
            <input asp-for="Recordarme" class="form-check-input shadow-sm" />
            <label asp-for="Recordarme" class="form-check-label small text-muted">Mantener sesión iniciada</label>
        </div>

        <partial name="_CaptchaTurnstile" />

        <button type="submit" class="btn btn-ep w-100 py-3 mb-4 d-flex align-items-center justify-content-center gap-2">
            Ingresar <i class="bi bi-arrow-right"></i>
        </button>
    </form>

    <div class="position-relative my-4">
        <hr class="text-muted opacity-25">
        <span class="position-absolute top-50 start-50 translate-middle px-3 small text-muted bg-card" style="background: var(--ep-fondo);">o</span>
    </div>

    <a asp-action="IniciarSesionGoogle" class="btn w-100 py-3 mb-3 d-flex align-items-center justify-content-center gap-2 border-0" style="background: #fff; color: #1f1f1f; border: 1px solid #dadce0 !important;">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.49h4.84a4.14 4.14 0 0 1-1.8 2.71v2.26h2.92a8.78 8.78 0 0 0 2.68-6.62z" fill="#4285F4"/><path d="M9 18a8.6 8.6 0 0 0 5.96-2.18l-2.92-2.26a5.4 5.4 0 0 1-8.08-2.84H.96v2.33A9 9 0 0 0 9 18z" fill="#34A853"/><path d="M4.96 10.72a5.4 5.4 0 0 1 0-3.44V4.95H.96a9 9 0 0 0 0 8.1l4-4.33z" fill="#FBBC05"/><path d="M9 3.58c1.32 0 2.5.46 3.44 1.35l2.58-2.59A9 9 0 0 0 .96 4.95l4 4.33c.6-1.8 2.14-3.1 4.04-3.7z" fill="#EA4335"/></svg>
        Continuar con Google
    </a>

    <div class="text-center">
        <p class="small text-muted mb-0">¿Aún no tienes una cuenta? <a asp-action="Registro" class="text-primary text-decoration-none fw-semibold">Regístrate ahora</a></p>
    </div>

    <div class="text-end mt-3">
        <a asp-controller="Admin" asp-action="Login" class="btn btn-link p-0 small text-muted text-decoration-none">Acceso admin</a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
