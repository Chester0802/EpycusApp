@model EpycusApp.ViewModels.RegistroViewModel

@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "_LayoutAuth";
}

<div class="ep-card ep-card-neon p-4">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center mb-3 auth-icon-box" style="width: 64px; height: 64px; border-radius: 1rem; background: var(--ep-superficie-2); color: var(--ep-primario);">
            <i class="bi bi-person-plus fs-2"></i>
        </div>
        <h2 class="fw-bold mb-1">Crear cuenta</h2>
        <p class="text-muted small">Empieza tu camino con Epycus.</p>
    </div>

    <form asp-action="Registro" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control ep-input" placeholder="Nombre completo" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CorreoElectronico" class="form-label"></label>
            <input asp-for="CorreoElectronico" class="form-control ep-input" placeholder="correo@ejemplo.com" />
            <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Contrasena" class="form-label"></label>
                <input asp-for="Contrasena" class="form-control ep-input" placeholder="••••••••" />
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ConfirmarContrasena" class="form-label"></label>
                <input asp-for="ConfirmarContrasena" class="form-control ep-input" placeholder="••••••••" />
                <span asp-validation-for="ConfirmarContrasena" class="text-danger small"></span>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-6">
                <label asp-for="FechaNacimiento" class="form-label"></label>
                <input asp-for="FechaNacimiento" type="date" class="form-control ep-input" />
                <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Genero" class="form-label"></label>
                <select asp-for="Genero" class="form-select ep-input">
                    <option value="">Seleccione</option>
                    <option value="Masculino">Masculino</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Prefiero no decir">Prefiero no decir</option>
                </select>
                <span asp-validation-for="Genero" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3 mt-3">
            <label asp-for="CarreraId" class="form-label">Carrera</label>
            <select asp-for="CarreraId" class="form-select ep-input">
                <option value="">Seleccione</option>
                @foreach (var carrera in (ViewBag.Carreras as List<EpycusApp.Models.Entidades.Carrera> ?? new List<EpycusApp.Models.Entidades.Carrera>()))
                {
                    <option value="@carrera.Id">@carrera.Nombre</option>
                }
            </select>
            <span asp-validation-for="CarreraId" class="text-danger small"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="AceptoTerminos" class="form-check-input" />
            <label asp-for="AceptoTerminos" class="form-check-label">Acepto los términos y condiciones</label>
            <span asp-validation-for="AceptoTerminos" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-ep w-100">Crear cuenta</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
