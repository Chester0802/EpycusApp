@model EpycusApp.ViewModels.PerfilViewModel
@using EpycusApp.Models.Entidades

@{
    ViewData["Title"] = "Ajustes";
    var carreras = ViewBag.Carreras as List<Carrera> ?? new List<Carrera>();
    var imagenPersonaje = ViewData["ImagenPersonaje"]?.ToString()
                       ?? "/img/personajes/generico/masculino/placeholder.png";
}

<!-- Header -->
<div class="ep-header">
    <h1 class="ep-header-title">
        <i class="bi bi-gear-wide-connected" style="color: var(--accent-primary);"></i>
        Ajustes
    </h1>
    <p class="ep-header-subtitle">Administra tu cuenta, perfil y preferencias</p>
</div>

<!-- Mensajes de feedback -->
@if (TempData["Mensaje"] != null)
{
    <div class="ep-alerta mb-4" role="alert">
        <i class="bi bi-check-circle-fill ep-alerta-icono" style="color: var(--success);"></i>
        <div>
            <div class="ep-alerta-titulo">Cambio guardado</div>
            <div style="color: var(--text-secondary);">@TempData["Mensaje"]</div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ep-alerta mb-4" style="border-left-color: var(--error);" role="alert">
        <i class="bi bi-exclamation-triangle-fill ep-alerta-icono" style="color: var(--error);"></i>
        <div>
            <div class="ep-alerta-titulo" style="color: var(--error);">Ocurrió un problema</div>
            <div style="color: var(--text-secondary);">@TempData["Error"]</div>
        </div>
    </div>
}

<div class="row g-4">
    <!-- Columna Izquierda: Tarjeta de perfil + navegación de secciones -->
    <div class="col-lg-3">
        <!-- Tarjeta de perfil compacta -->
        <div class="ep-card text-center mb-3">
            @if (!string.IsNullOrEmpty(Model.FotoGoogleUrl))
            {
                <img src="@Model.FotoGoogleUrl" alt="Foto de perfil"
                     class="rounded-circle mb-3 shadow"
                     style="width: min(88px, 30vw); height: min(88px, 30vw); border: 3px solid var(--accent-primary); object-fit: cover;" />
            }
            else
            {
                <img src="@imagenPersonaje" alt="Personaje"
                     class="rounded-circle mb-3 shadow"
                     style="width: min(88px, 30vw); height: min(88px, 30vw); border: 3px solid var(--accent-primary); object-fit: cover; object-position: center 8%; background: var(--bg-elevated);" />
            }
            <h5 class="fw-bold mb-0" style="color: var(--text-primary);">@Model.Nombre</h5>
            <p class="small mb-1" style="color: var(--text-secondary);">@Model.CorreoElectronico</p>
            <span class="badge px-2 py-1" style="background: var(--accent-primary-bg, rgba(139,92,246,0.15)); color: var(--accent-primary); font-size: 0.7rem;">
                <i class="bi bi-hash me-1"></i>@Model.CodigoUnico
            </span>
            @if (Model.UsaGoogle)
            {
                <div class="mt-2">
                    <span class="badge px-2 py-1" style="background: var(--info-bg); color: var(--info); font-size: 0.7rem;">
                        <i class="bi bi-google me-1"></i>Google
                    </span>
                </div>
            }
        </div>

        <!-- Stats rápidas -->
        <div class="ep-card mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2 pb-2" style="border-bottom: 1px solid var(--border-color);">
                <span class="small" style="color: var(--text-secondary);">Nivel</span>
                <span class="fw-bold" style="color: var(--accent-primary);">@Model.NivelActual</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-2 pb-2" style="border-bottom: 1px solid var(--border-color);">
                <span class="small" style="color: var(--text-secondary);">XP Total</span>
                <span class="fw-bold" style="color: var(--info);">@Model.XpTotal</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-2 pb-2" style="border-bottom: 1px solid var(--border-color);">
                <span class="small" style="color: var(--text-secondary);">Racha actual</span>
                <span class="fw-bold" style="color: var(--warning);"><i class="bi bi-fire me-1"></i>@Model.RachaActual días</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="small" style="color: var(--text-secondary);">Racha máxima</span>
                <span class="fw-bold" style="color: var(--success);"><i class="bi bi-trophy me-1"></i>@Model.RachaMaxima días</span>
            </div>
        </div>

        <!-- Navegación de secciones -->
        <div class="ep-card p-2">
            <a href="#seccion-perfil" class="ep-nav-item mb-1" style="font-size: 0.88rem;">
                <i class="bi bi-person-circle"></i> Información personal
            </a>
            @if (!Model.UsaGoogle)
            {
                <a href="#seccion-seguridad" class="ep-nav-item mb-1" style="font-size: 0.88rem;">
                    <i class="bi bi-shield-lock"></i> Seguridad
                </a>
            }
            <a href="#seccion-apariencia" class="ep-nav-item mb-1" style="font-size: 0.88rem;">
                <i class="bi bi-palette"></i> Apariencia
            </a>
            <a href="#seccion-personaje" class="ep-nav-item mb-1" style="font-size: 0.88rem;">
                <i class="bi bi-person-bounding-box"></i> Mi Personaje
            </a>
            <a href="#seccion-cuenta" class="ep-nav-item" style="font-size: 0.88rem; color: var(--error) !important;">
                <i class="bi bi-exclamation-octagon"></i> Zona de peligro
            </a>
        </div>
    </div>

    <!-- Columna Derecha: Secciones -->
    <div class="col-lg-9">

        <!-- ── SECCIÓN: Información Personal ── -->
        <div class="ep-card mb-4" id="seccion-perfil">
            <h4 class="fw-bold mb-1 d-flex align-items-center gap-2" style="color: var(--text-primary);">
                <i class="bi bi-person-circle" style="color: var(--accent-primary);"></i>
                Información personal
            </h4>
            <p class="small mb-4" style="color: var(--text-secondary);">Actualiza tu nombre, carrera y datos básicos.</p>

            <form asp-action="ActualizarPerfil" method="post">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label for="Nombre" class="form-label small fw-semibold" style="color: var(--text-primary);">
                            Nombre completo
                        </label>
                        <input type="text" class="form-control ep-input" id="Nombre" name="Nombre"
                               value="@Model.Nombre" required maxlength="150" />
                    </div>

                    <div class="col-md-6">
                        <label for="FechaNacimiento" class="form-label small fw-semibold" style="color: var(--text-primary);">
                            Fecha de nacimiento
                        </label>
                        <input type="date" class="form-control ep-input" id="FechaNacimiento" name="FechaNacimiento"
                               value="@(Model.FechaNacimiento.HasValue ? Model.FechaNacimiento.Value.ToString("yyyy-MM-dd") : String.Empty)" required />
                    </div>

                    <div class="col-md-6">
                        <label for="Genero" class="form-label small fw-semibold" style="color: var(--text-primary);">
                            Género
                        </label>
                        <select class="form-select ep-input" id="Genero" name="Genero" required>
                            <option value="Masculino" selected="@(Model.Genero == "Masculino")">Masculino</option>
                            <option value="Femenino" selected="@(Model.Genero == "Femenino")">Femenino</option>
                            <option value="Prefiero no decir" selected="@(Model.Genero == "Prefiero no decir")">Prefiero no decir</option>
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label for="CarreraId" class="form-label small fw-semibold" style="color: var(--text-primary);">
                            Carrera
                        </label>
                        @if (carreras.Any())
                        {
                            <select class="form-select ep-input" id="CarreraId" name="CarreraId" required>
                                @foreach (var c in carreras)
                                {
                                    <option value="@c.Id" selected="@(c.Id == Model.CarreraId)">@c.Nombre</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="hidden" name="CarreraId" value="@Model.CarreraId" />
                            <div class="form-control ep-input" style="cursor: default;">@Model.CarreraNombre</div>
                            <small style="color: var(--text-tertiary);">Contacta al administrador para cambiar tu carrera</small>
                        }
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="ep-btn ep-btn-primary">
                        <i class="bi bi-check2-circle me-2"></i>Guardar cambios
                    </button>
                </div>
            </form>
        </div>

        <!-- ── SECCIÓN: Seguridad (solo si no usa Google) ── -->
        @if (!Model.UsaGoogle)
        {
            <div class="ep-card mb-4" id="seccion-seguridad">
                <h4 class="fw-bold mb-1 d-flex align-items-center gap-2" style="color: var(--text-primary);">
                    <i class="bi bi-shield-lock" style="color: var(--accent-primary);"></i>
                    Seguridad
                </h4>
                <p class="small mb-4" style="color: var(--text-secondary);">Actualiza tu contraseña de acceso.</p>

                <form asp-action="CambiarContrasena" method="post">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label for="ContrasenaActual" class="form-label small fw-semibold" style="color: var(--text-primary);">
                                Contraseña actual
                            </label>
                            <div class="input-group">
                                <input type="password" class="form-control ep-input" id="ContrasenaActual" name="ContrasenaActual" required placeholder="••••••••" />
                                <button class="btn" type="button" style="background: var(--bg-elevated); border-color: var(--border-color); color: var(--text-secondary);" onclick="togglePass('ContrasenaActual', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="NuevaContrasena" class="form-label small fw-semibold" style="color: var(--text-primary);">
                                Nueva contraseña
                            </label>
                            <div class="input-group">
                                <input type="password" class="form-control ep-input" id="NuevaContrasena" name="NuevaContrasena"
                                       minlength="6" required placeholder="Mínimo 6 caracteres" />
                                <button class="btn" type="button" style="background: var(--bg-elevated); border-color: var(--border-color); color: var(--text-secondary);" onclick="togglePass('NuevaContrasena', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label for="ConfirmarContrasena" class="form-label small fw-semibold" style="color: var(--text-primary);">
                                Confirmar contraseña
                            </label>
                            <div class="input-group">
                                <input type="password" class="form-control ep-input" id="ConfirmarContrasena" name="ConfirmarContrasena"
                                       minlength="6" required placeholder="Repite la nueva contraseña" />
                                <button class="btn" type="button" style="background: var(--bg-elevated); border-color: var(--border-color); color: var(--text-secondary);" onclick="togglePass('ConfirmarContrasena', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Indicador de fortaleza de contraseña -->
                    <div class="mt-3 d-none" id="strength-box">
                        <div class="d-flex gap-1 mb-1">
                            <div class="strength-bar rounded" id="sb1" style="height:6px; flex:1; background: var(--border-color); transition: background 0.3s;"></div>
                            <div class="strength-bar rounded" id="sb2" style="height:6px; flex:1; background: var(--border-color); transition: background 0.3s;"></div>
                            <div class="strength-bar rounded" id="sb3" style="height:6px; flex:1; background: var(--border-color); transition: background 0.3s;"></div>
                            <div class="strength-bar rounded" id="sb4" style="height:6px; flex:1; background: var(--border-color); transition: background 0.3s;"></div>
                        </div>
                        <p class="small mb-0" id="strength-text" style="color: var(--text-secondary);"></p>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="ep-btn ep-btn-primary">
                            <i class="bi bi-key me-2"></i>Actualizar contraseña
                        </button>
                    </div>
                </form>
            </div>
        }

        <!-- ── SECCIÓN: Apariencia ── -->
        <div class="ep-card mb-4" id="seccion-apariencia">
            <h4 class="fw-bold mb-1 d-flex align-items-center gap-2" style="color: var(--text-primary);">
                <i class="bi bi-palette" style="color: var(--accent-primary);"></i>
                Apariencia
            </h4>
            <p class="small mb-4" style="color: var(--text-secondary);">Personaliza el aspecto visual de la aplicación.</p>

            <label class="form-label small fw-semibold mb-3" style="color: var(--text-primary);">Tema de color</label>
            <div class="row g-3" id="selector-temas">
                <!-- Tema Oscuro -->
                <div class="col-6 col-md-4">
                    <div class="tema-card p-3 rounded cursor-pointer @(Model.TemaActualId == null || Model.TemaActualId == 1 ? "tema-activo" : "")"
                         onclick="seleccionarTema(1, 'oscuro')"
                         style="border: 2px solid @(Model.TemaActualId == null || Model.TemaActualId == 1 ? "var(--accent-primary)" : "var(--border-color)"); cursor: pointer; transition: all 0.2s; background: var(--bg-elevated);">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #1a1a2e, #16213e);"></div>
                            <div>
                                <div class="fw-semibold small" style="color: var(--text-primary);">Noche épica</div>
                                <div style="font-size: 0.7rem; color: var(--text-secondary);">Oscuro</div>
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <div style="width: 20px; height: 8px; border-radius: 4px; background: #8b5cf6;"></div>
                            <div style="width: 20px; height: 8px; border-radius: 4px; background: #3b82f6;"></div>
                            <div style="width: 20px; height: 8px; border-radius: 4px; background: #10b981;"></div>
                        </div>
                    </div>
                </div>
                <!-- Tema Claro -->
                <div class="col-6 col-md-4">
                    <div class="tema-card p-3 rounded cursor-pointer @(Model.TemaActualId == 2 ? "tema-activo" : "")"
                         onclick="seleccionarTema(2, 'claro')"
                         style="border: 2px solid @(Model.TemaActualId == 2 ? "var(--accent-primary)" : "var(--border-color)"); cursor: pointer; transition: all 0.2s; background: var(--bg-elevated);">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div style="width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #fce7f3, #fbcfe8);"></div>
                            <div>
                                <div class="fw-semibold small" style="color: var(--text-primary);">Sakura</div>
                                <div style="font-size: 0.7rem; color: var(--text-secondary);">Claro</div>
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <div style="width: 20px; height: 8px; border-radius: 4px; background: #ec4899;"></div>
                            <div style="width: 20px; height: 8px; border-radius: 4px; background: #a855f7;"></div>
                            <div style="width: 20px; height: 8px; border-radius: 4px; background: #06b6d4;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="small mt-3 mb-0" style="color: var(--text-secondary);">
                <i class="bi bi-info-circle me-1"></i>
                También puedes cambiar el tema rápidamente con el botón en la barra lateral.
            </p>
        </div>

        <!-- ── SECCIÓN: Mi Personaje ── -->
        <div class="ep-card mb-4" id="seccion-personaje">
            <h4 class="fw-bold mb-1 d-flex align-items-center gap-2" style="color: var(--text-primary);">
                <i class="bi bi-person-bounding-box" style="color: var(--accent-primary);"></i>
                Mi Personaje
            </h4>
            <p class="small mb-4" style="color: var(--text-secondary);">
                Elige el avatar que te represente. Evolucionará visualmente a medida que subas de nivel.
            </p>

            @if (Model.PersonajesDisponibles.Any())
            {
                <div class="personaje-grid">
                    @foreach (var p in Model.PersonajesDisponibles)
                    {
                        <button type="button"
                                class="personaje-card @(p.EsSeleccionado ? "seleccionado" : "")"
                                onclick="seleccionarPersonaje(@p.Id, this)"
                                aria-pressed="@p.EsSeleccionado.ToString().ToLower()"
                                aria-label="Seleccionar personaje @p.Nombre">
                            @if (p.EsSeleccionado)
                            {
                                <span class="personaje-check" aria-hidden="true">
                                    <i class="fas fa-check"></i>
                                </span>
                            }
                            <div class="personaje-card-img">
                                <img src="@p.ImagenPreviewUrl"
                                     alt="@p.Nombre"
                                     onerror="this.src='/img/personajes/generico/masculino/placeholder.png'" />
                            </div>
                            <div class="personaje-card-info">
                                <span class="personaje-nombre">@p.Nombre</span>
                                <span class="personaje-genero-badge">
                                    @(p.Genero == "Masculino" ? "♂ Masculino" : "♀ Femenino")
                                </span>
                                @if (p.EsSeleccionado)
                                {
                                    <span class="personaje-activo-badge">Activo</span>
                                }
                                @if (p.EsPlaceholder)
                                {
                                    <span class="personaje-placeholder-note">Imagen próximamente</span>
                                }
                            </div>
                        </button>
                    }
                </div>
                <p class="small mt-3 mb-0" style="color: var(--text-secondary);">
                    <i class="bi bi-info-circle me-1"></i>
                    Se añadirán más personajes para otras carreras progresivamente.
                </p>
            }
            else
            {
                <div class="text-center py-4" style="color: var(--text-secondary);">
                    <i class="bi bi-person-x" style="font-size: 2.5rem; display: block; margin-bottom: 0.75rem; color: var(--text-tertiary);"></i>
                    <p class="mb-0 small">No hay personajes disponibles para tu carrera aún. ¡Pronto habrá más!</p>
                </div>
            }
        </div>

        <!-- ── SECCIÓN: Zona de peligro ── -->
        <div class="ep-card mb-4" id="seccion-cuenta" style="border-color: rgba(239,68,68,0.25);">
            <h4 class="fw-bold mb-1 d-flex align-items-center gap-2" style="color: var(--error);">
                <i class="bi bi-exclamation-octagon"></i>
                Zona de peligro
            </h4>
            <p class="small mb-4" style="color: var(--text-secondary);">Estas acciones son irreversibles. Procede con cuidado.</p>

            <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 p-3 rounded" style="background: rgba(239,68,68,0.07); border: 1px solid rgba(239,68,68,0.2);">
                <div class="flex-fill min-w-0">
                    <div class="fw-semibold small" style="color: var(--text-primary);">Cerrar sesión en todos los dispositivos</div>
                    <div class="small" style="color: var(--text-secondary);">Invalida todos tus tokens de acceso activos.</div>
                </div>
                <form asp-controller="Autenticacion" asp-action="Logout" method="post" class="flex-shrink-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="ep-btn btn-sm" style="background: transparent; border: 1px solid var(--error); color: var(--error);">
                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Toggle visibilidad de contraseña
    function togglePass(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    // Indicador de fortaleza de contraseña
    const inputNueva = document.getElementById('NuevaContrasena');
    if (inputNueva) {
        inputNueva.addEventListener('input', function () {
            const val = this.value;
            const box = document.getElementById('strength-box');
            if (!val) { box.classList.add('d-none'); return; }
            box.classList.remove('d-none');

            let score = 0;
            if (val.length >= 6) score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
            if (/[0-9]/.test(val) && /[^A-Za-z0-9]/.test(val)) score++;

            const colors = ['', 'var(--error)', 'var(--warning)', 'var(--info)', 'var(--success)'];
            const labels = ['', 'Muy débil', 'Débil', 'Fuerte', 'Muy fuerte'];
            for (let i = 1; i <= 4; i++) {
                document.getElementById('sb' + i).style.background = i <= score ? colors[score] : 'var(--border-color)';
            }
            document.getElementById('strength-text').textContent = labels[score];
            document.getElementById('strength-text').style.color = colors[score];
        });
    }

    // Validar que las contraseñas coincidan
    const inputConfirmar = document.getElementById('ConfirmarContrasena');
    if (inputConfirmar) {
        inputConfirmar.addEventListener('input', function () {
            const nueva = document.getElementById('NuevaContrasena').value;
            if (this.value && this.value !== nueva) {
                this.style.borderColor = 'var(--error)';
            } else {
                this.style.borderColor = '';
            }
        });
    }

    // Selector de personaje
    async function seleccionarPersonaje(personajeId, tarjeta) {
        try {
            const res = await fetch('/Ajustes/CambiarPersonaje', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'personajeId=' + personajeId,
                credentials: 'same-origin'
            });
            const data = await res.json();

            if (data.exito) {
                // Actualizar imagen en el sidebar
                const sidebarImg = document.querySelector('.ep-sidebar-character-img');
                if (sidebarImg) {
                    sidebarImg.src = data.imagenUrl + '?t=' + Date.now();
                }

                // Actualizar estado visual de las tarjetas
                document.querySelectorAll('.personaje-card').forEach(c => {
                    c.classList.remove('seleccionado');
                    c.setAttribute('aria-pressed', 'false');
                    // Quitar checkmark y badge activo
                    const chk = c.querySelector('.personaje-check');
                    if (chk) chk.remove();
                    const badge = c.querySelector('.personaje-activo-badge');
                    if (badge) badge.remove();
                });

                tarjeta.classList.add('seleccionado');
                tarjeta.setAttribute('aria-pressed', 'true');

                // Insertar checkmark
                const check = document.createElement('span');
                check.className = 'personaje-check';
                check.setAttribute('aria-hidden', 'true');
                check.innerHTML = '<i class="fas fa-check"></i>';
                tarjeta.prepend(check);

                // Insertar badge activo
                const info = tarjeta.querySelector('.personaje-card-info');
                if (info) {
                    const badge = document.createElement('span');
                    badge.className = 'personaje-activo-badge';
                    badge.textContent = 'Activo';
                    info.appendChild(badge);
                }

                if (typeof Notificaciones !== 'undefined') {
                    Notificaciones.mostrarExito('¡Personaje actualizado correctamente!');
                }
            }
        } catch {
            if (typeof Notificaciones !== 'undefined') {
                Notificaciones.mostrarError('Error al cambiar el personaje.');
            }
        }
    }

    // Selector de tema
    async function seleccionarTema(temaId, nombreTema) {
        try {
            const res = await fetch('/Ajustes/CambiarTema', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'temaId=' + temaId,
                credentials: 'same-origin'
            });
            const data = await res.json();

            if (data.exito) {
                // Aplicar tema visualmente
                const hojaTema = document.getElementById('hoja-tema');
                if (hojaTema) {
                    hojaTema.href = nombreTema === 'claro'
                        ? '/css/temas/tema-sakura.css'
                        : '/css/temas/tema-noche-epica.css';
                }
                localStorage.setItem('epycus_theme', nombreTema);

                // Actualizar selección visual
                document.querySelectorAll('.tema-card').forEach(c => {
                    c.style.borderColor = 'var(--border-color)';
                });
                event.currentTarget.style.borderColor = 'var(--accent-primary)';

                if (typeof window.Notificaciones !== 'undefined') {
                    Notificaciones.mostrarExito('Tema actualizado correctamente.');
                }
            }
        } catch (e) {
            console.error('Error al cambiar tema:', e);
        }
    }
</script>
}
