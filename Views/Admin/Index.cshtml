@model EPYCUS_WEB_v0._1.ViewModels.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Panel Admin";
    Layout = "_LayoutAdmin";
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Panel administrativo <i class="bi bi-speedometer2 text-primary"></i></h1>
    <p class="ep-header-subtitle">Supervisa la actividad general del sistema.</p>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <div class="ep-card">
            <div class="d-flex align-items-center gap-3">
                <div class="ep-boton-icono"><i class="bi bi-people"></i></div>
                <div>
                    <div class="text-muted small">Usuarios totales</div>
                    <div class="h4 mb-0 fw-bold">@Model.TotalUsuarios</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ep-card">
            <div class="d-flex align-items-center gap-3">
                <div class="ep-boton-icono"><i class="bi bi-person-check"></i></div>
                <div>
                    <div class="text-muted small">Usuarios activos</div>
                    <div class="h4 mb-0 fw-bold">@Model.UsuariosActivos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ep-card">
            <div class="d-flex align-items-center gap-3">
                <div class="ep-boton-icono"><i class="bi bi-stars"></i></div>
                <div>
                    <div class="text-muted small">Suscripciones activas</div>
                    <div class="h4 mb-0 fw-bold">@Model.SuscripcionesActivas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ep-card">
            <div class="d-flex align-items-center gap-3">
                <div class="ep-boton-icono"><i class="bi bi-chat-quote"></i></div>
                <div>
                    <div class="text-muted small">Frases motivacionales</div>
                    <div class="h4 mb-0 fw-bold">@Model.TotalFrases</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="ep-card mt-4">
    <h5 class="mb-2">Acciones rápidas</h5>
    <p class="text-muted">Accede rápidamente a los módulos principales del panel.</p>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Usuarios" class="btn btn-ep">Gestionar usuarios</a>
        <a asp-action="Frases" class="btn btn-ep-outline">Gestionar frases</a>
    </div>
</div>
