@model EPYCUS_WEB_v0._1.ViewModels.HomeDashboardViewModel

@{
    ViewData["Title"] = "Inicio";
}

@if (Model != null && Model.EstaAutenticado)
{
    <div class="mb-4">
        <h1 class="ep-header-title d-flex align-items-center gap-2">
            ¡Hola, @Model.NombreUsuario! <i class="bi bi-stars text-warning"></i>
        </h1>
        @if (!string.IsNullOrEmpty(Model.FraseMotivacional))
        {
            <p class="ep-header-subtitle">
                <em>"@Model.FraseMotivacional"</em> - <strong>@Model.AutorFrase</strong>
            </p>
        }
    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="ep-summary-card">
                <div class="ep-summary-icon icon-purple">
                    <i class="bi bi-list-check"></i>
                </div>
                <div>
                    <p class="ep-summary-value">@Model.Estadisticas.TotalHabitos</p>
                    <p class="ep-summary-label">Hábitos activos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ep-summary-card">
                <div class="ep-summary-icon icon-green">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <div>
                    <p class="ep-summary-value">@Model.Estadisticas.TotalCompletadosHoy</p>
                    <p class="ep-summary-label">Completados hoy</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ep-summary-card">
                <div class="ep-summary-icon icon-orange">
                    <i class="bi bi-fire"></i>
                </div>
                <div>
                    <p class="ep-summary-value">@Model.Estadisticas.RachaActualMaxima</p>
                    <p class="ep-summary-label text-warning">Mejor racha actual</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Hábitos de Hoy -->
        <div class="col-lg-7">
            <div class="ep-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 fw-bold">Tus hábitos para hoy</h5>
                    <a asp-controller="Habitos" asp-action="Index" class="btn btn-sm btn-ep-outline">Ver todos</a>
                </div>

                @if (Model.HabitosHoy == null || !Model.HabitosHoy.Any())
                {
                    <div class="alert alert-info bg-transparent border-info text-info">
                        No tienes hábitos programados para hoy. ¡Disfruta tu día!
                    </div>
                }
                else
                {
                    @foreach (var h in Model.HabitosHoy)
                    {
                        <div class="ep-habit-card" data-habito-id="@h.Id">
                            <div class="ep-habit-icon icon-blue">
                                <i class="bi bi-journal-check"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold">@h.Nombre</h6>
                                <span class="badge" style="background: rgba(16, 185, 129, 0.15); color: #10B981;">@h.CategoriaNombre</span>
                            </div>
                            <div class="me-4 text-secondary d-none d-sm-block" style="font-size: 0.85rem;">
                                <div class="text-warning racha-cell"><i class="bi bi-fire me-1"></i>@h.RachaActual días</div>
                            </div>
                            <div class="ms-2">
                                <button class="btn btn-sm btn-primary rounded-pill px-3 btn-completar" onclick="completarHabitoDashboard(@h.Id, this)">100%</button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Columna Derecha: Tabla Gráfica -->
        <div class="col-lg-5">
            <div class="ep-card h-100">
                <h5 class="mb-3 fw-bold">Distribución por categoría</h5>
                <div class="text-center" style="height: 300px; position: relative;">
                    <canvas id="graficoCategorias"></canvas>
                </div>
                <div class="mt-4 text-center text-muted small">
                    Mantén un equilibrio en tus hábitos para un mejor estilo de vida.
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            // Función para completar el hábito desde el Dashboard
            async function completarHabitoDashboard(id, btn) {
                btn.disabled = true;
                const originalText = btn.innerText;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                
                try {
                    const res = await fetch(`/api/apihabitos/${id}/completar`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin'
                    });

                    if (!res.ok) {
                        const json = await res.json().catch(()=>null);
                        alert(json?.mensaje ?? 'No se pudo completar el hábito');
                        btn.innerText = originalText;
                        return;
                    }

                    const data = await res.json();
                    
                    // Mostrar éxito visual
                    btn.className = 'btn btn-sm btn-success rounded-pill px-3';
                    btn.innerHTML = '<i class="bi bi-check2"></i> XP +'+data.xp;
                    
                    // Actualizar fila racha
                    const fila = document.querySelector(`.ep-habit-card[data-habito-id="${id}"]`);
                    if (fila) {
                        const rachaCell = fila.querySelector('.racha-cell');
                        if (rachaCell) {
                            const texto = rachaCell.innerText;
                            const num = parseInt(texto.replace(/[^0-9]/g, '')) || 0;
                            rachaCell.innerHTML = `<i class="bi bi-fire me-1"></i>${num + 1} días`;
                        }
                    }
                } catch (e) {
                    alert('Error de red al completar el hábito');
                    btn.innerText = originalText;
                } finally {
                    setTimeout(() => { btn.disabled = false; }, 1000);
                }
            }

            // Renderizar gráfico de Chart.js
            document.addEventListener('DOMContentLoaded', function() {
                var ctx = document.getElementById('graficoCategorias');
                if (!ctx) return;

                var categorias = @Html.Raw(Json.Serialize(Model.Estadisticas.DistribucionPorCategoria.Keys));
                var valores = @Html.Raw(Json.Serialize(Model.Estadisticas.DistribucionPorCategoria.Values));
                
                var esModoOscuro = localStorage.getItem('epycus_theme') !== 'claro';
                var colorTexto = esModoOscuro ? '#E2E8F0' : '#1E293B';

                // Colores vibrantes y modernos
                var coloresBg = [
                    'rgba(59, 130, 246, 0.8)',   // Azul
                    'rgba(16, 185, 129, 0.8)',   // Verde
                    'rgba(245, 158, 11, 0.8)',   // Naranja
                    'rgba(167, 139, 250, 0.8)',  // Púrpura
                    'rgba(236, 72, 153, 0.8)',   // Rosa
                    'rgba(14, 165, 233, 0.8)'    // Cyan
                ];

                var myChart = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: categorias,
                        datasets: [{
                            data: valores,
                            backgroundColor: coloresBg,
                            borderWidth: 2,
                            borderColor: esModoOscuro ? '#1E293B' : '#FFFFFF',
                            hoverOffset: 10
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    color: colorTexto,
                                    padding: 20,
                                    font: {
                                        family: "'Inter', sans-serif",
                                        size: 13
                                    }
                                }
                            },
                            tooltip: {
                                backgroundColor: esModoOscuro ? 'rgba(15, 23, 42, 0.9)' : 'rgba(255, 255, 255, 0.9)',
                                titleColor: esModoOscuro ? '#fff' : '#000',
                                bodyColor: esModoOscuro ? '#CBD5E1' : '#334155',
                                padding: 12,
                                borderColor: 'rgba(128, 128, 128, 0.2)',
                                borderWidth: 1
                            }
                        },
                        cutout: '70%'
                    }
                });

                // Re-render en cambio de tema
                document.getElementById('switch-tema')?.addEventListener('change', function(e) {
                    var isDark = e.target.checked;
                    myChart.options.plugins.legend.labels.color = isDark ? '#E2E8F0' : '#1E293B';
                    myChart.data.datasets[0].borderColor = isDark ? '#1E293B' : '#FFFFFF';
                    myChart.options.plugins.tooltip.backgroundColor = isDark ? 'rgba(15, 23, 42, 0.9)' : 'rgba(255, 255, 255, 0.9)';
                    myChart.options.plugins.tooltip.titleColor = isDark ? '#fff' : '#000';
                    myChart.options.plugins.tooltip.bodyColor = isDark ? '#CBD5E1' : '#334155';
                    myChart.update();
                });
            });
        </script>
    }
}
else
{
    <div class="ep-card">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h1 class="ep-header-title mb-3">Bienvenido a Epycus</h1>
                <p class="ep-header-subtitle">Organiza tus hábitos, misiones y sesiones Pomodoro con un sistema visual diseñado para motivarte cada día.</p>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a asp-controller="Autenticacion" asp-action="Login" class="btn btn-ep"><i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión</a>
                    <a asp-controller="Autenticacion" asp-action="Registro" class="btn btn-ep-outline"><i class="bi bi-person-plus me-2"></i>Crear Cuenta</a>
                </div>
            </div>
            <div class="col-lg-5 text-center">
                <div class="ep-card-neon p-4">
                    <i class="bi bi-graph-up-arrow text-primary display-4"></i>
                    <h5 class="mt-3 mb-2">Tu progreso visible</h5>
                    <p class="text-muted mb-0">Mide tu avance con indicadores claros y celebra cada logro.</p>
                </div>
            </div>
        </div>
    </div>
}
