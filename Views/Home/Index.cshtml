@model EpycusApp.ViewModels.HomeDashboardViewModel

@{
    ViewData["Title"] = "Inicio";
}

@if (Model != null && Model.EstaAutenticado)
{
    <div class="mb-4">
        <h1 class="ep-header-title d-flex align-items-center gap-2">
            ¡Hola, @Model.NombreUsuario! <i class="bi bi-stars text-warning"></i>
        </h1>
        @if (!string.IsNullOrEmpty(Model.FraseMotivacional))
        {
            <p class="ep-header-subtitle">
                <em>"@Model.FraseMotivacional"</em> - <strong>@Model.AutorFrase</strong>
            </p>
        }
    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="ep-summary-card">
                <div class="ep-summary-icon icon-purple">
                    <i class="bi bi-list-check"></i>
                </div>
                <div>
                    <p class="ep-summary-value">@Model.Estadisticas.TotalHabitos</p>
                    <p class="ep-summary-label">Hábitos activos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ep-summary-card">
                <div class="ep-summary-icon icon-green">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <div>
                    <p class="ep-summary-value">@Model.Estadisticas.TotalCompletadosHoy</p>
                    <p class="ep-summary-label">Completados hoy</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ep-summary-card">
                <div class="ep-summary-icon icon-orange">
                    <i class="bi bi-fire"></i>
                </div>
                <div>
                    <p class="ep-summary-value">@Model.Estadisticas.RachaActualMaxima</p>
                    <p class="ep-summary-label text-warning">Mejor racha actual</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Hábitos de Hoy -->
        <div class="col-lg-7">
            <div class="ep-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 fw-bold">Tus hábitos para hoy</h5>
                    <a asp-controller="Habitos" asp-action="Index" class="btn btn-sm btn-ep-outline">Ver todos</a>
                </div>

                @if (Model.HabitosHoy == null || !Model.HabitosHoy.Any())
                {
                    <div class="alert alert-info bg-transparent border-info text-info">
                        No tienes hábitos programados para hoy. ¡Disfruta tu día!
                    </div>
                }
                else
                {
                    @foreach (var h in Model.HabitosHoy)
                    {
                        <div class="ep-habit-card" data-habito-id="@h.Id">
                            <div class="ep-habit-icon icon-blue">
                                <i class="bi bi-journal-check"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-1 fw-bold">@h.Nombre</h6>
                                <span class="badge" style="background: rgba(16, 185, 129, 0.15); color: #10B981;">@h.CategoriaNombre</span>
                            </div>
                            <div class="me-4 text-secondary d-none d-md-block" style="font-size: 0.85rem;">
                                <div class="text-warning racha-cell"><i class="bi bi-fire me-1"></i>@h.RachaActual días</div>
                            </div>
                            <div class="ms-2">
                                <button class="btn btn-sm btn-primary rounded-pill px-3 btn-completar" onclick="completarHabitoDashboard(@h.Id, this)">100%</button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Columna Derecha: Tabla Gráfica -->
        <div class="col-lg-5">
            <div class="ep-card h-100">
                <h5 class="mb-3 fw-bold">Distribución por categoría</h5>
                <div class="text-center" style="height: clamp(200px, 40vw, 300px); position: relative;">
                    <canvas id="graficoCategorias"
                            data-categorias='@Html.Raw(Json.Serialize(Model.Estadisticas.DistribucionPorCategoria.Keys))'
                            data-valores='@Html.Raw(Json.Serialize(Model.Estadisticas.DistribucionPorCategoria.Values))'>
                    </canvas>
                </div>
                <div class="mt-4 text-center text-muted small">
                    Mantén un equilibrio en tus hábitos para un mejor estilo de vida.
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script src="~/lib/chart.min.js" asp-append-version="true"></script>
        <script src="~/js/dashboard.js" asp-append-version="true"></script>
    }
}
else
{
    <div class="ep-card">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h1 class="ep-header-title mb-3">Bienvenido a Epycus</h1>
                <p class="ep-header-subtitle">Organiza tus hábitos, misiones y sesiones Pomodoro con un sistema visual diseñado para motivarte cada día.</p>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a asp-controller="Autenticacion" asp-action="Login" class="btn btn-ep"><i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión</a>
                    <a asp-controller="Autenticacion" asp-action="Registro" class="btn btn-ep-outline"><i class="bi bi-person-plus me-2"></i>Crear Cuenta</a>
                </div>
            </div>
            <div class="col-lg-5 text-center">
                <div class="ep-card-neon p-4">
                    <i class="bi bi-graph-up-arrow text-primary display-4"></i>
                    <h5 class="mt-3 mb-2">Tu progreso visible</h5>
                    <p class="text-muted mb-0">Mide tu avance con indicadores claros y celebra cada logro.</p>
                </div>
            </div>
        </div>
    </div>
}
