@model EpycusApp.ViewModels.BienestarViewModel

@{
    ViewData["Title"] = "Bienestar";

    var estadoConfig = new Dictionary<string, (string Emoji, string Color, string BgColor, string Label)>
    {
        ["Genial"]    = ("😄", "var(--ep-animo-genial)",    "var(--ep-animo-genial-bg)",    "Genial"),
        ["Bien"]      = ("🙂", "var(--ep-animo-bien)",      "var(--ep-animo-bien-bg)",      "Bien"),
        ["Normal"]    = ("😐", "var(--ep-animo-normal)",    "var(--ep-animo-normal-bg)",    "Normal"),
        ["Cansado"]   = ("😴", "var(--ep-animo-cansado)",   "var(--ep-animo-cansado-bg)",   "Cansado"),
        ["Estresado"] = ("😰", "var(--ep-animo-estresado)", "var(--ep-animo-estresado-bg)", "Estresado")
    };

    string EstadoColor(string e) => estadoConfig.TryGetValue(e, out var c) ? c.Color : "var(--ep-texto-secundario)";
    string EstadoBg(string e)    => estadoConfig.TryGetValue(e, out var c) ? c.BgColor : "transparent";
    string EstadoEmoji(string e) => estadoConfig.TryGetValue(e, out var c) ? c.Emoji : "•";
}

<link rel="stylesheet" href="~/css/bienestar.css" asp-append-version="true" />

<!-- Header con branding ODS 3 -->
<div class="ep-header d-flex flex-wrap align-items-center justify-content-between gap-2">
    <div>
        <h1 class="ep-header-title">
            <i class="fas fa-heart-pulse" style="color: var(--accent-primary);"></i>
            Bienestar
        </h1>
        <p class="ep-header-subtitle mb-0">Cuida tu energía, tu ánimo y tu equilibrio diario.</p>
    </div>
    <a href="https://www.un.org/sustainabledevelopment/es/health/" target="_blank" rel="noopener" class="ep-ods-badge">
        <i class="bi bi-flag"></i>
        ODS 3 &middot; Salud y Bienestar
    </a>
</div>

<partial name="_MensajeFeedback" />

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ep-summary-stat">
            <div class="fs-4 fw-bold" style="color: var(--ep-animo-genial);">@Model.EstadoHoy?.Estado ?? "—"</div>
            <div class="small text-muted">Estado hoy</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ep-summary-stat">
            <div class="fs-4 fw-bold" style="color: var(--accent-primary);">@Model.HabitosPendientes</div>
            <div class="small text-muted">Hábitos pendientes</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ep-summary-stat">
            <div class="fs-4 fw-bold" style="color: var(--ep-animo-estresado);">@Model.MisionesPendientes</div>
            <div class="small text-muted">Misiones pendientes</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ep-summary-stat">
            <div class="fs-4 fw-bold" style="color: var(--info);">@Model.Alertas.Count</div>
            <div class="small text-muted">Alertas activas</div>
        </div>
    </div>
</div>

<!-- Recomendación activa -->
@if (Model.RecomendacionActiva != null)
{
    <div class="ep-card mb-4 d-flex align-items-center gap-3 py-3"
         style="background: rgba(var(--ep-primario-rgb, 255,107,157),0.06); border-color: rgba(var(--ep-primario-rgb, 255,107,157),0.2);">
        <i class="bi @Model.RecomendacionActiva.Icono fs-3 flex-shrink-0" style="color: var(--accent-primary);"></i>
        <div class="flex-grow-1">
            <div class="fw-semibold small" style="color: var(--accent-primary);">@Model.RecomendacionActiva.Tipo</div>
            <div class="small text-muted">@Model.RecomendacionActiva.Descripcion</div>
        </div>
        <span class="small text-muted flex-shrink-0">@(Model.RecomendacionActiva.DuracionSegundos / 60) min</span>
    </div>
}

<div class="row g-4">
    <!-- Col izquierda: Ánimo hoy + Frase -->
    <div class="col-lg-5">
        <!-- Tarjeta: Cómo te sientes hoy -->
        <div class="ep-card mb-4">
            <h5 class="fw-semibold mb-1 d-flex align-items-center gap-2">
                <i class="bi bi-emoji-smile" style="color: var(--accent-primary);"></i>
                ¿Cómo te sientes hoy?
            </h5>
            <p class="text-muted small mb-4">
                @if (Model.EstadoHoy != null)
                {
                    <span>Ya registraste: </span>
                    <strong style="color: @EstadoColor(Model.EstadoHoy.Estado);">
                        @EstadoEmoji(Model.EstadoHoy.Estado) @Model.EstadoHoy.Estado
                    </strong>
                    <span class="ms-2 text-muted">(puedes cambiarlo)</span>
                }
                else
                {
                    <span>Selecciona tu estado para que Epycus pueda ayudarte mejor.</span>
                }
            </p>

            <form asp-action="RegistrarAnimo" method="post">
                @Html.AntiForgeryToken()
                <div class="d-flex flex-wrap gap-2 mb-4" id="animoPicker">
                    @foreach (var kv in estadoConfig)
                    {
                        var esActual = Model.EstadoHoy?.Estado == kv.Key;
                        <button type="button"
                                class="ep-animo-btn @(esActual ? "activo" : "")"
                                data-estado="@kv.Key"
                                style="--animo-color: @kv.Value.Color; --animo-bg: @kv.Value.BgColor;"
                                onclick="seleccionarAnimo('@kv.Key', this)">
                            <span class="fs-4">@kv.Value.Emoji</span>
                            <span class="small fw-medium">@kv.Value.Label</span>
                        </button>
                    }
                </div>

                <input type="hidden" name="estado" id="estadoSeleccionado" value="@(Model.EstadoHoy?.Estado ?? "")" />

                <div class="mb-3">
                    <label class="form-label small fw-semibold text-muted">Nota opcional</label>
                    <textarea name="nota" class="form-control ep-input" rows="2"
                              placeholder="¿Qué está influyendo en tu día?"
                              style="resize: none;">@(Model.EstadoHoy?.Nota ?? "")</textarea>
                </div>

                <button type="submit" id="btnRegistrar" class="btn btn-ep w-100 d-flex align-items-center justify-content-center gap-2"
                        @(Model.EstadoHoy == null ? "disabled" : "")>
                    <i class="bi bi-check-lg"></i>
                    @(Model.EstadoHoy != null ? "Actualizar estado" : "Registrar estado")
                </button>
            </form>
        </div>

        <!-- Frase motivacional -->
        @if (Model.FraseMotivacional != null)
        {
            <div class="ep-card" style="background: linear-gradient(135deg, rgba(var(--ep-primario-rgb, 255,107,157),0.08), rgba(var(--ep-primario-rgb, 255,107,157),0.03)); border-color: rgba(var(--ep-primario-rgb, 255,107,157),0.2);">
                <i class="bi bi-quote fs-2 mb-2" style="color: var(--accent-primary); opacity: 0.5;"></i>
                <p class="fst-italic mb-2" style="color: var(--ep-texto-primario); line-height: 1.6;">
                    "@Model.FraseMotivacional.Frase"
                </p>
                <p class="small text-muted mb-0">— @Model.FraseMotivacional.Autor</p>
                <span class="small" style="color: var(--ep-texto-terciario);">@Model.FraseMotivacional.Categoria</span>
            </div>
        }
    </div>

    <!-- Col derecha: Alertas + Historial -->
    <div class="col-lg-7">
        <!-- Alertas de bienestar -->
        @if (Model.Alertas.Any())
        {
            <div class="mb-4">
                <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-bell" style="color: var(--accent-primary);"></i>
                    Alertas activas
                    <span class="badge rounded-pill ms-1" style="background: var(--ep-animo-estresado-bg); color: var(--ep-animo-estresado); font-size: 0.7rem;">@Model.Alertas.Count</span>
                </h5>
                @foreach (var alerta in Model.Alertas)
                {
                    var colorAlerta = alerta.EsCritica ? "var(--ep-animo-estresado)" : "var(--ep-animo-cansado)";
                    var bgAlerta = alerta.EsCritica ? "var(--ep-animo-estresado-bg)" : "var(--ep-animo-cansado-bg)";
                    <div class="ep-card mb-3 d-flex gap-3 align-items-start"
                         style="background: @bgAlerta; border-color: @colorAlerta; border-left: 3px solid @colorAlerta;">
                        <i class="bi @alerta.Icono fs-4 flex-shrink-0 mt-1" style="color: @colorAlerta;"></i>
                        <div>
                            <div class="small fw-semibold mb-1" style="color: @colorAlerta;">@alerta.Tipo</div>
                            <div class="small text-muted">@alerta.Mensaje</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="ep-card mb-4 d-flex align-items-center gap-3"
                 style="background: var(--ep-animo-genial-bg); border-color: var(--ep-animo-genial);">
                <i class="bi bi-shield-check fs-3 flex-shrink-0" style="color: var(--ep-animo-genial);"></i>
                <div>
                    <div class="fw-semibold small" style="color: var(--ep-animo-genial);">Todo en orden</div>
                    <div class="small text-muted">No hay alertas de bienestar activas. ¡Sigue así!</div>
                </div>
            </div>
        }

        <!-- Recursos de crisis / salud mental -->
        <div class="ep-card mb-4">
            <h5 class="fw-semibold mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-shield-heart" style="color: var(--accent-primary);"></i>
                Recursos de apoyo
            </h5>
            <div class="row g-2">
                <div class="col-sm-6">
                    <a href="https://www.linea113.pe/" target="_blank" rel="noopener" class="ep-recursos-card d-block p-3 text-decoration-none">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-telephone fs-5" style="color: var(--accent-primary);"></i>
                            <span class="fw-semibold small">Línea 113</span>
                        </div>
                        <div class="small text-muted">Atención en salud mental — disponible 24/7</div>
                    </a>
                </div>
                <div class="col-sm-6">
                    <a href="https://www.un.org/sustainabledevelopment/es/health/" target="_blank" rel="noopener" class="ep-recursos-card d-block p-3 text-decoration-none">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-globe fs-5" style="color: var(--accent-primary);"></i>
                            <span class="fw-semibold small">ONU ODS 3</span>
                        </div>
                        <div class="small text-muted">Objetivo: Salud y Bienestar para todos</div>
                    </a>
                </div>
                <div class="col-sm-6">
                    <div class="ep-recursos-card p-3">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-wind fs-5" style="color: var(--accent-primary);"></i>
                            <span class="fw-semibold small">Respiración guiada</span>
                        </div>
                        <div class="small text-muted mb-2">Inhala 4s — Retén 7s — Exhala 8s</div>
                        <button type="button" class="btn btn-sm btn-ep-outline" onclick="iniciarRespiracion()">
                            <i class="bi bi-play-circle me-1"></i>Iniciar
                        </button>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="ep-recursos-card p-3">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-emoji-smile fs-5" style="color: var(--accent-primary);"></i>
                            <span class="fw-semibold small">Consejo del día</span>
                        </div>
                        <div class="small text-muted">Tomar descansos cortos mejora tu concentración hasta un 40%</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Historial de ánimo -->
        <div class="ep-card">
            <h5 class="fw-semibold mb-4 d-flex align-items-center gap-2">
                <i class="bi bi-calendar3" style="color: var(--accent-primary);"></i>
                Historial de ánimo (14 días)
            </h5>

            @if (!Model.HistorialAnimo.Any())
            {
                <div class="text-center py-4 text-muted small">
                    <i class="bi bi-calendar-x fs-2 d-block mb-2 opacity-50"></i>
                    Aún no has registrado ningún estado de ánimo.
                </div>
            }
            else
            {
                <div class="d-flex gap-2 flex-wrap mb-4">
                    @{
                        var hoy = DateOnly.FromDateTime(DateTime.Today);
                        var historialDict = Model.HistorialAnimo.ToDictionary(e => e.Fecha);
                    }
                    @for (int i = 13; i >= 0; i--)
                    {
                        var fecha = hoy.AddDays(-i);
                        var tieneRegistro = historialDict.TryGetValue(fecha, out var reg);
                        var color = tieneRegistro ? EstadoColor(reg!.Estado) : "var(--ep-borde)";
                        var emoji = tieneRegistro ? EstadoEmoji(reg!.Estado) : "·";
                        var esDomingo = fecha.DayOfWeek == DayOfWeek.Sunday;
                        <div class="text-center ep-animo-circle" style="min-width: 28px; max-width: 36px; flex: 0 0 auto;">
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-1"
                                 style="width: clamp(24px, 6vw, 32px); height: clamp(24px, 6vw, 32px); background: @(tieneRegistro ? EstadoBg(reg!.Estado) : "var(--ep-superficie-2)"); border: 1px solid @color;"
                                 title="@fecha.ToString("dd/MM")@(tieneRegistro ? ": " + reg!.Estado : "")">
                                @if (tieneRegistro)
                                {
                                    <span style="font-size: clamp(0.7rem, 2vw, 0.9rem);">@emoji</span>
                                }
                                else
                                {
                                    <span style="font-size: 0.5rem; color: var(--ep-texto-secundario);">—</span>
                                }
                            </div>
                            <div class="small" style="font-size: 0.6rem; color: var(--ep-texto-secundario);">
                                @fecha.ToString("dd")
                            </div>
                        </div>
                        if (esDomingo && i > 0)
                        {
                            <div style="width: 1px; align-self: stretch; background: var(--ep-borde); margin: 0 2px;"></div>
                        }
                    }
                </div>

                <div class="d-flex flex-column gap-2" style="max-height: 280px; overflow-y: auto;">
                    @foreach (var entry in Model.HistorialAnimo)
                    {
                        <div class="d-flex align-items-center gap-3 py-2 px-3 rounded-3"
                             style="background: @EstadoBg(entry.Estado);">
                            <span class="fs-5 flex-shrink-0">@EstadoEmoji(entry.Estado)</span>
                            <div class="flex-grow-1">
                                <div class="small fw-semibold" style="color: @EstadoColor(entry.Estado);">@entry.Estado</div>
                                @if (!string.IsNullOrWhiteSpace(entry.Nota))
                                {
                                    <div class="small text-muted">@entry.Nota</div>
                                }
                            </div>
                            <div class="small text-muted flex-shrink-0">@entry.Fecha.ToString("dd MMM")</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Mini componente de respiración guiada -->
<div class="modal fade" id="respiracionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background: var(--ep-superficie); border-color: var(--ep-borde);">
            <div class="modal-body text-center py-5">
                <div id="respiracionCirculo" style="width: 120px; height: 120px; border-radius: 50%; margin: 0 auto 1.5rem; background: var(--accent-primary); opacity: 0.3; transition: all 4s ease-in-out;"></div>
                <div id="respiracionTexto" class="fw-semibold mb-2" style="color: var(--ep-texto-primario);">Inhala</div>
                <div id="respiracionTiempo" class="small text-muted">4s</div>
                <button class="btn btn-sm btn-ep-outline mt-3" onclick="detenerRespiracion()">
                    <i class="bi bi-stop-circle me-1"></i>Detener
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function seleccionarAnimo(estado, btn) {
        document.querySelectorAll('.ep-animo-btn').forEach(b => b.classList.remove('activo'));
        btn.classList.add('activo');
        document.getElementById('estadoSeleccionado').value = estado;
        document.getElementById('btnRegistrar').disabled = false;
    }

    let respiracionInterval = null;
    let respiracionActiva = false;

    function iniciarRespiracion() {
        const modal = new bootstrap.Modal(document.getElementById('respiracionModal'));
        modal.show();

        const circulo = document.getElementById('respiracionCirculo');
        const texto = document.getElementById('respiracionTexto');
        const tiempo = document.getElementById('respiracionTiempo');
        const fases = [
            { texto: 'Inhala', duracion: 4000, escala: 1.4, opacidad: 0.8 },
            { texto: 'Retén', duracion: 7000, escala: 1.4, opacidad: 0.8 },
            { texto: 'Exhala', duracion: 8000, escala: 1, opacidad: 0.3 }
        ];
        let faseActual = 0;
        let segundosRestantes = 0;

        respiracionActiva = true;

        function ejecutarFase() {
            if (!respiracionActiva) return;
            const fase = fases[faseActual];
            texto.textContent = fase.texto;
            segundosRestantes = Math.floor(fase.duracion / 1000);
            tiempo.textContent = segundosRestantes + 's';
            circulo.style.transition = `all ${fase.duracion}ms ease-in-out`;
            circulo.style.transform = `scale(${fase.escala})`;
            circulo.style.opacity = fase.opacidad;

            if (respiracionInterval) clearInterval(respiracionInterval);
            respiracionInterval = setInterval(() => {
                segundosRestantes--;
                if (segundosRestantes <= 0) {
                    clearInterval(respiracionInterval);
                    faseActual = (faseActual + 1) % fases.length;
                    if (respiracionActiva) ejecutarFase();
                } else {
                    tiempo.textContent = segundosRestantes + 's';
                }
            }, 1000);

            setTimeout(() => {
                if (respiracionActiva) {
                    faseActual = (faseActual + 1) % fases.length;
                    ejecutarFase();
                }
            }, fase.duracion);
        }

        ejecutarFase();
    }

    function detenerRespiracion() {
        respiracionActiva = false;
        if (respiracionInterval) clearInterval(respiracionInterval);
        const modalEl = document.getElementById('respiracionModal');
        const modal = bootstrap.Modal.getInstance(modalEl);
        if (modal) modal.hide();
    }
</script>
