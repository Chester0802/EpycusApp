@model EPYCUS_WEB_v0._1.ViewModels.HabitosIndexViewModel

@{
    ViewData["Title"] = "Hábitos";
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Hábitos <i class="bi bi-bullseye text-primary"></i></h1>
    <p class="ep-header-subtitle">Pequeñas acciones diarias, grandes cambios.</p>
    <div class="d-flex flex-wrap gap-2 mt-3">
        <button class="btn btn-ep" data-bs-toggle="modal" data-bs-target="#modalCrear"><i class="bi bi-plus-lg me-2"></i>Nuevo hábito</button>
        <button class="btn btn-ep-outline"><i class="bi bi-tags me-2"></i>Categorías</button>
    </div>
</div>

<!-- Tarjetas de resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="ep-summary-card">
            <div class="ep-summary-icon icon-purple">
                <i class="bi bi-check-circle"></i>
            </div>
            <div>
                <p class="ep-summary-value">@Model.Dashboard.TotalHabitos</p>
                <p class="ep-summary-label">Total hábitos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ep-summary-card">
            <div class="ep-summary-icon icon-green">
                <i class="bi bi-check2-circle"></i>
            </div>
            <div>
                <p class="ep-summary-value">@Model.Dashboard.TotalCompletadosHoy</p>
                <p class="ep-summary-label">Completados hoy</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ep-summary-card">
            <div class="ep-summary-icon icon-orange">
                <i class="bi bi-fire"></i>
            </div>
            <div>
                <p class="ep-summary-value">@Model.Dashboard.RachaActualMaxima</p>
                <p class="ep-summary-label text-warning">Racha actual <br><small>¡Sigue así!</small></p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ep-summary-card">
            <div class="ep-summary-icon icon-blue">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div>
                @{
                    int totalSemana = Model.Dashboard.CompletadosSemana + Model.Dashboard.ParcialesSemana + Model.Dashboard.OmitidosSemana;
                    int porcExito = totalSemana == 0 ? 0 : (int)Math.Round((double)Model.Dashboard.CompletadosSemana / totalSemana * 100);
                }
                <p class="ep-summary-value">@porcExito%</p>
                <p class="ep-summary-label">Tasa de éxito <br><small>Últimos 7 días</small></p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Columna Izquierda: Lista de Hábitos -->
    <div class="col-lg-8">
        <div class="ep-card mb-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center ep-tabs">
                <div>
                    <a href="#" class="ep-tab active">Todos</a>
                    <a href="#" class="ep-tab">Activos</a>
                    <a href="#" class="ep-tab">Completados</a>
                    <a href="#" class="ep-tab">Archivados</a>
                </div>
                <div>
                    <select class="form-select form-select-sm bg-transparent border-secondary text-white">
                        <option>Ordenar por: Prioridad</option>
                    </select>
                </div>
            </div>

            <!-- Cabecera de días -->
            <div class="d-flex justify-content-end mb-2 pe-3 text-secondary" style="font-size: 0.85rem; gap: 1rem;">
                <span style="width: 24px; text-align: center;">Lun</span>
                <span style="width: 24px; text-align: center;">Mar</span>
                <span style="width: 24px; text-align: center;">Mié</span>
                <span style="width: 24px; text-align: center;">Jue</span>
                <span style="width: 24px; text-align: center;">Vie</span>
                <span style="width: 24px; text-align: center;">Sáb</span>
                <span style="width: 24px; text-align: center;">Dom</span>
                <span style="width: 40px; text-align: center; font-weight: bold; color: var(--ep-texto);">Hoy</span>
            </div>

            @if (Model?.Habitos == null || !Model.Habitos.Any())
            {
                <div class="alert alert-info bg-transparent border-info text-info">No hay hábitos todavía. ¡Empieza creando uno nuevo!</div>
            }
            else
            {
                @foreach (var h in Model.Habitos)
                {
                    <div class="ep-habit-card" data-habito-id="@h.Id">
                        <div class="ep-habit-icon icon-blue">
                            <!-- Ícono genérico por ahora -->
                            <i class="bi bi-journal-check"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-1 fw-bold">@h.Nombre</h6>
                            <span class="badge" style="background: rgba(16, 185, 129, 0.15); color: #10B981;">@h.CategoriaNombre</span>
                        </div>
                        <div class="me-4 text-secondary" style="font-size: 0.85rem;">
                            <div class="mb-1"><i class="bi bi-calendar-event me-1"></i>@h.Frecuencia</div>
                            <div class="text-warning racha-cell"><i class="bi bi-fire me-1"></i>@h.RachaActual días</div>
                        </div>
                        
                        <!-- Checkboxes de días (Simulados visualmente) -->
                        <div class="d-flex align-items-center" style="gap: 1rem;">
                            <!-- Lun a Dom (Visual representativo) -->
                            <div class="ep-day-check checked"><i class="bi bi-check"></i></div>
                            <div class="ep-day-check checked"><i class="bi bi-check"></i></div>
                            <div class="ep-day-check disabled"></div>
                            <div class="ep-day-check checked"><i class="bi bi-check"></i></div>
                            <div class="ep-day-check checked"><i class="bi bi-check"></i></div>
                            <div class="ep-day-check disabled"></div>
                            <div class="ep-day-check disabled"></div>
                            
                            <!-- Botón Hoy -->
                            <div class="ms-2">
                                <button class="btn btn-sm btn-primary rounded-pill px-3" onclick="completarHabito(@h.Id, this)">100%</button>
                            </div>
                            
                            <div class="dropdown ms-2">
                                <button class="btn btn-sm btn-link text-secondary p-0" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" href="/habitos/editar/@h.Id">Editar</a></li>
                                    <li>
                                        <form asp-action="Eliminar" method="post">
                                            <input type="hidden" name="id" value="@h.Id" />
                                            <button type="submit" class="dropdown-item text-danger">Eliminar</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="ep-alerta mt-4">
            <i class="bi bi-lightbulb ep-alerta-icono"></i>
            <div>
                <div class="ep-alerta-titulo">Tip diario</div>
                <div class="text-muted">Los hábitos pequeños y constantes generan grandes resultados.</div>
            </div>
        </div>
    </div>

    <!-- Columna Derecha: Sidebar -->
    <div class="col-lg-4">
        <!-- Botones de Acción -->
        <div class="mb-4 d-flex gap-2">
            <button class="ep-sidebar-btn ep-btn-purple flex-grow-1 m-0" data-bs-toggle="modal" data-bs-target="#modalCrear">
                <i class="bi bi-plus-lg me-1"></i> Nuevo hábito
            </button>
            <button class="ep-sidebar-btn ep-btn-white flex-grow-1 m-0">
                <i class="bi bi-tags me-1"></i> Categorías
            </button>
        </div>

        <!-- Resumen semanal -->
        <div class="ep-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0 fw-bold">Resumen semanal</h5>
                <select class="form-select form-select-sm bg-transparent border-secondary text-white" style="width: auto;">
                    <option>Esta semana</option>
                </select>
            </div>
            
            <div class="row align-items-center">
                <div class="col-5">
                    <div class="ep-donut-wrapper">
                        <div class="ep-donut">
                            <div class="ep-donut-inner">
                                <span class="ep-donut-val">@porcExito%</span>
                                <span class="ep-donut-label text-center">Éxito<br>semanal</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-7">
                    <ul class="list-unstyled mb-0" style="font-size: 0.9rem;">
                        <li class="d-flex justify-content-between mb-2">
                            <span><i class="bi bi-circle-fill text-success me-2" style="font-size: 0.5rem;"></i> Completados</span>
                            <span class="fw-bold">@Model.Dashboard.CompletadosSemana</span>
                        </li>
                        <li class="d-flex justify-content-between mb-2">
                            <span><i class="bi bi-circle-fill text-warning me-2" style="font-size: 0.5rem;"></i> Parciales</span>
                            <span class="fw-bold">@Model.Dashboard.ParcialesSemana</span>
                        </li>
                        <li class="d-flex justify-content-between mb-3">
                            <span><i class="bi bi-circle-fill text-danger me-2" style="font-size: 0.5rem;"></i> Omitidos</span>
                            <span class="fw-bold">@Model.Dashboard.OmitidosSemana</span>
                        </li>
                        <li class="border-top border-secondary pt-2 text-secondary">
                            Total hábitos: @Model.Dashboard.TotalHabitos
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Mejores rachas -->
        <div class="ep-card mb-4">
            <h5 class="mb-3 fw-bold">Mejores rachas</h5>
            <ul class="list-unstyled mb-3">
                @foreach (var r in Model.Dashboard.MejoresRachas)
                {
                    <li class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom border-secondary" style="font-size: 0.95rem;">
                        <span><i class="bi bi-journal text-info me-2"></i> @r.Nombre</span>
                        <span class="text-success fw-bold">@r.Dias días</span>
                    </li>
                }
            </ul>
            <a href="#" class="text-primary text-decoration-none" style="font-size: 0.9rem;">Ver todas las rachas <i class="bi bi-arrow-right"></i></a>
        </div>

        <!-- Distribución por categoría -->
        <div class="ep-card">
            <h5 class="mb-3 fw-bold">Distribución por categoría</h5>
            
            <div class="row align-items-center">
                <div class="col-5">
                    <!-- Simple CSS pie chart for categories -->
                    <div style="width: 100px; height: 100px; border-radius: 50%; background: conic-gradient(#3B82F6 0% 40%, #A78BFA 40% 70%, #F59E0B 70% 90%, #10B981 90% 100%); margin: 0 auto;"></div>
                </div>
                <div class="col-7">
                    <ul class="list-unstyled mb-0" style="font-size: 0.85rem;">
                        @foreach (var kv in Model.Dashboard.DistribucionPorCategoria)
                        {
                            <li class="d-flex justify-content-between mb-2">
                                <span><i class="bi bi-circle-fill text-primary me-2" style="font-size: 0.5rem;"></i> @kv.Key</span>
                                <span class="fw-bold">@kv.Value</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <div class="mt-3 text-secondary" style="font-size: 0.85rem;">
                @Model.Dashboard.TotalHabitos hábitos en total
            </div>
        </div>
    </div>
</div>

<!-- Modal para crear hábito -->
<div class="modal fade" id="modalCrear" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary">
            <form id="formCrearHabito" asp-action="Crear" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">Crear hábito</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label class="form-label text-secondary">Nombre</label>
                        <input name="Nombre" class="form-control bg-transparent text-white border-secondary" placeholder="Ej: Leer 20 páginas" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary">Descripción</label>
                        <textarea name="Descripcion" class="form-control bg-transparent text-white border-secondary" rows="2"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary">Categoría</label>
                        @{ var categorias = ViewBag.Categorias as List<EPYCUS_WEB_v0._1.Modelos.Entidades.Categoria> ?? new List<EPYCUS_WEB_v0._1.Modelos.Entidades.Categoria>(); }
                        <select name="CategoriaId" class="form-select bg-transparent text-white border-secondary" required>
                            <option value="" class="text-dark">-- Seleccione --</option>
                            @foreach(var c in categorias)
                            {
                                <option value="@c.Id" class="text-dark">@c.Nombre</option>
                            }
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label text-secondary">Frecuencia</label>
                            <select name="Frecuencia" class="form-select bg-transparent text-white border-secondary">
                                <option value="Diaria" class="text-dark">Diaria</option>
                                <option value="Semanal" class="text-dark">Semanal</option>
                                <option value="Personalizada" class="text-dark">Personalizada</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-secondary">Días (Ej: 1,3,5)</label>
                            <input name="DiasSemana" class="form-control bg-transparent text-white border-secondary" placeholder="1=Lun...7=Dom" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="form-check mt-4">
                                <input name="ConPomodoro" type="checkbox" class="form-check-input" id="chkPomodoro" value="true" />
                                <label class="form-check-label text-secondary" for="chkPomodoro">Usar Pomodoro</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label text-secondary">Hora recordatorio</label>
                            <input name="RecordatorioHora" type="time" class="form-control bg-transparent text-white border-secondary" />
                        </div>
                    </div>

                    <div class="form-check d-none">
                        <input name="EstaActivo" type="checkbox" checked class="form-check-input" value="true" />
                    </div>
                </div>

                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn ep-btn-purple px-4">Crear</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function completarHabito(id, btn) {
            btn.disabled = true;
            const originalText = btn.innerText;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
            
            try {
                const res = await fetch(`/api/apihabitos/${id}/completar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin'
                });

                if (!res.ok) {
                    const json = await res.json().catch(()=>null);
                    alert(json?.mensaje ?? 'No se pudo completar el hábito');
                    btn.innerText = originalText;
                    return;
                }

                const data = await res.json();
                
                // Mostrar éxito visual
                btn.className = 'btn btn-sm btn-success rounded-pill px-3';
                btn.innerHTML = '<i class="bi bi-check2"></i> XP +'+data.xp;
                
                // actualizar fila sin recargar
                const fila = document.querySelector(`.ep-habit-card[data-habito-id="${id}"]`);
                if (fila) {
                    const rachaCell = fila.querySelector('.racha-cell');
                    if (rachaCell) {
                        const texto = rachaCell.innerText;
                        const num = parseInt(texto.replace(/[^0-9]/g, '')) || 0;
                        rachaCell.innerHTML = `<i class="bi bi-fire me-1"></i>${num + 1} días`;
                    }
                }
            } catch (e) {
                alert('Error de red al completar el hábito');
                btn.innerText = originalText;
            } finally {
                setTimeout(() => { btn.disabled = false; }, 1000);
            }
        }
    </script>

    <script>
        // Interceptar envío del formulario del modal y usar fetch para mayor control
        (function(){
            const form = document.getElementById('formCrearHabito');
            if (!form) return;
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                const btn = form.querySelector('button[type="submit"]');
                if (btn) btn.disabled = true;

                const formData = new FormData(form);
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenInput ? tokenInput.value : null;

                try {
                    const headers = token ? { 'RequestVerificationToken': token, 'X-Requested-With': 'XMLHttpRequest' } : { 'X-Requested-With': 'XMLHttpRequest' };

                    const res = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin',
                        headers
                    });

                    if (!res.ok) {
                        if (res.redirected || res.status === 401) {
                            alert('Necesitas iniciar sesión para crear un hábito.');
                            return;
                        }

                        const text = await res.text();
                        try {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(text, 'text/html');
                            const nuevoBody = doc.querySelector('.modal-body') || doc.querySelector('form');
                            const modalContent = document.querySelector('#modalCrear .modal-content');
                            if (nuevoBody && modalContent) {
                                const bodyEl = modalContent.querySelector('.modal-body');
                                if (bodyEl) bodyEl.innerHTML = nuevoBody.innerHTML;
                            } else {
                                alert('Error al crear hábito (código ' + res.status + ').');
                            }
                        } catch (e) {
                            alert('Error al crear hábito (respuesta inesperada).');
                        }
                        return;
                    }

                    const contentType = res.headers.get('content-type') || '';
                    if (contentType.indexOf('application/json') !== -1) {
                        const json = await res.json().catch(()=>null);
                        if (json && json.success) {
                            location.reload();
                            return;
                        }
                        if (json && json.errors) {
                            const modalContent = document.querySelector('#modalCrear .modal-content');
                            const bodyEl = modalContent.querySelector('.modal-body');
                            if (bodyEl) {
                                let summary = '<div class="alert alert-danger p-2 mb-3">';
                                for (const k in json.errors) {
                                    json.errors[k].forEach(msg => summary += '<div><small>' + msg + '</small></div>');
                                }
                                summary += '</div>';
                                bodyEl.insertAdjacentHTML('afterbegin', summary);
                            }
                        }
                        return;
                    }

                    if (contentType.indexOf('text/html') !== -1) {
                        const text = await res.text();
                        try {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(text, 'text/html');
                            const nuevoBody = doc.querySelector('.modal-body') || doc.querySelector('form');
                            const modalContent = document.querySelector('#modalCrear .modal-content');
                            if (nuevoBody && modalContent) {
                                const bodyEl = modalContent.querySelector('.modal-body');
                                if (bodyEl) bodyEl.innerHTML = nuevoBody.innerHTML;
                                return;
                            }
                            alert('Necesitas iniciar sesión para crear un hábito.');
                            return;
                        } catch (e) {
                            alert('Error al procesar la respuesta del servidor.');
                            return;
                        }
                    }

                    location.reload();
                } catch (err) {
                    alert('Error al crear hábito: ' + err);
                } finally {
                    if (btn) btn.disabled = false;
                }
            });
        })();
    </script>
}
