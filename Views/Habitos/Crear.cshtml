@model EPYCUS_WEB_v0._1.ViewModels.CrearHabitoViewModel

@{
    ViewData["Title"] = "Crear hábito";
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Crear hábito <i class="bi bi-plus-circle text-primary"></i></h1>
    <p class="ep-header-subtitle">Define un hábito claro y fácil de cumplir.</p>
</div>

<form asp-action="Crear" method="post" class="ep-card">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control ep-input" placeholder="Ej: Leer 20 minutos" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control ep-input" rows="3" placeholder="Describe cómo y cuándo lo harás"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoriaId" class="form-label">Categoría</label>
        @{ var categorias = ViewBag.Categorias as List<EPYCUS_WEB_v0._1.Models.Entidades.Categoria> ?? new List<EPYCUS_WEB_v0._1.Models.Entidades.Categoria>(); }
        <select asp-for="CategoriaId" class="form-select ep-input">
            <option value="">-- Seleccione --</option>
            @foreach(var c in categorias)
            {
                <option value="@c.Id">@c.Nombre</option>
            }
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Frecuencia" class="form-label"></label>
        <select asp-for="Frecuencia" class="form-select ep-input">
            <option value="Diaria">Diaria</option>
            <option value="Semanal">Semanal</option>
            <option value="Personalizada">Personalizada</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Días de la semana (números separados por comas)</label>
        <input name="DiasSemana" class="form-control ep-input" placeholder="Ej: 1,3,5" />
        <div class="form-text text-muted">Usa 1=Lun, 2=Mar, 3=Mié, 4=Jue, 5=Vie, 6=Sáb, 0=Dom.</div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="ConPomodoro" class="form-check-input" />
        <label asp-for="ConPomodoro" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label asp-for="RecordatorioHora" class="form-label"></label>
        <input asp-for="RecordatorioHora" type="time" class="form-control ep-input" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="EstaActivo" class="form-check-input" />
        <label asp-for="EstaActivo" class="form-check-label"></label>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-ep">Crear hábito</button>
        <a asp-action="Index" class="btn btn-ep-outline">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
