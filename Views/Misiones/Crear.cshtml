@model EpycusApp.ViewModels.CrearMisionViewModel

@{
    ViewData["Title"] = "Crear Misión";
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Nueva misión <i class="bi bi-rocket text-primary"></i></h1>
    <p class="ep-header-subtitle">Define una misión concreta y alcanza tus objetivos.</p>
</div>

<div class="ep-card">
    <form asp-action="Crear" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Nombre" class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control ep-input" placeholder="Ej: Terminar informe" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control ep-input" rows="3" placeholder="Describe lo que necesitas completar"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="NombreCurso" class="form-label">Curso (Opcional)</label>
                <input asp-for="NombreCurso" class="form-control ep-input" placeholder="Ej: Matemática" />
                <span asp-validation-for="NombreCurso" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="FechaLimite" class="form-label">Fecha Límite</label>
                <input asp-for="FechaLimite" type="date" class="form-control ep-input" />
                <span asp-validation-for="FechaLimite" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="Prioridad" class="form-label">Prioridad</label>
                <select asp-for="Prioridad" class="form-select ep-input">
                    <option value="Baja">Baja</option>
                    <option value="Media">Media</option>
                    <option value="Alta">Alta</option>
                </select>
                <span asp-validation-for="Prioridad" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CategoriaId" class="form-label">Categoría</label>
                <select asp-for="CategoriaId" class="form-select ep-input" asp-items="ViewBag.Categorias">
                    <option value="">-- Seleccione una Categoría --</option>
                </select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="ConPomodoro" class="form-check-input" />
            <label asp-for="ConPomodoro" class="form-check-label">Usar Pomodoro</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-ep">Guardar misión</button>
            <a asp-action="Index" class="btn btn-ep-outline">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
