@model IEnumerable<EpycusApp.Models.Entidades.Mision>

@{
    ViewData["Title"] = "Misiones";
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Misiones <i class="bi bi-rocket text-primary"></i></h1>
    <p class="ep-header-subtitle">Enfoca tu energía en objetivos claros y medibles.</p>
    <a asp-action="Crear" class="btn btn-ep mt-3"><i class="bi bi-plus-lg me-2"></i>Nueva misión</a>
</div>

    @if (TempData["Exito"] != null)
    {
        <div class="ep-alerta mb-4">
            <i class="bi bi-check-circle-fill ep-alerta-icono"></i>
            <div>
                <div class="ep-alerta-titulo">Acción completada</div>
                <div class="text-muted">@TempData["Exito"]</div>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="ep-alerta mb-4">
            <i class="bi bi-exclamation-triangle-fill ep-alerta-icono"></i>
            <div>
                <div class="ep-alerta-titulo">Ocurrió un problema</div>
                <div class="text-muted">@TempData["Error"]</div>
            </div>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var mision in Model)
        {
            var colorPrioridad = mision.Prioridad switch
            {
                "Alta" => "danger",
                "Media" => "warning",
                "Baja" => "success",
                _ => "secondary"
            };

            var badgeEstado = mision.Estado switch
            {
                "Pendiente" => "bg-secondary",
                "EnProgreso" => "bg-primary",
                "Completado" => "bg-success",
                "Fallido" => "bg-danger",
                _ => "bg-light"
            };

            <div class="col">
                <div class="ep-card h-100">
                    <div class="d-flex justify-content-between mb-3">
                        <span class="badge @badgeEstado">@mision.Estado</span>
                        <span class="badge bg-@colorPrioridad text-white">@mision.Prioridad</span>
                    </div>
                    <h5 class="card-title fw-bold mb-1">@mision.Nombre</h5>
                    <p class="text-muted small mb-2">@mision.Categoria?.Nombre</p>
                    <p class="card-text">@mision.Descripcion</p>
                    <div class="d-flex align-items-center gap-2 text-muted small mb-3">
                        <i class="bi bi-calendar-event"></i>
                        <span>Límite: @mision.FechaLimite.ToString("dd/MM/yyyy")</span>
                    </div>
                        <div class="d-flex justify-content-between mb-2">
                        @if (mision.Estado == "Pendiente")
                        {
                            <form asp-action="CambiarEstado" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@mision.Id" />
                                <input type="hidden" name="estado" value="EnProgreso" />
                                <button type="submit" class="btn btn-ep-outline btn-sm">Iniciar</button>
                            </form>
                        }
                        else if (mision.Estado == "EnProgreso")
                        {
                            <form asp-action="Completar" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@mision.Id" />
                                <button type="submit" class="btn btn-ep btn-sm">Completar</button>
                            </form>
                        }

                        @if (mision.Estado != "Completado" && mision.Estado != "Fallido")
                        {
                            <a asp-action="Editar" asp-route-id="@mision.Id" class="btn btn-ep-outline btn-sm">Editar</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
