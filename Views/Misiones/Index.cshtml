@model IEnumerable<EpycusApp.Models.Entidades.Mision>

@{
    ViewData["Title"] = "Misiones";
    var activas = Model.Where(m => m.Estado != "Completado" && m.Estado != "Fallido");
    var completadas = Model.Where(m => m.Estado == "Completado" || m.Estado == "Fallido");
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Misiones <i class="bi bi-rocket text-primary"></i></h1>
    <p class="ep-header-subtitle">Enfoca tu energía en objetivos claros y medibles.</p>
    <a asp-action="Crear" class="btn btn-ep mt-3"><i class="bi bi-plus-lg me-2"></i>Nueva misión</a>
</div>

<div id="ep-spinner" class="ep-spinner-overlay"><div class="ep-spinner"></div><span class="ms-2">Cargando misiones...</span></div>
<partial name="_MensajeFeedback" />

@if (activas.Any())
{
    <h5 class="fw-bold mb-3 text-secondary"><i class="bi bi-lightning me-2"></i>Activas</h5>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
        @foreach (var mision in activas)
        {
            @await Html.PartialAsync("_TarjetaMision", mision)
        }
    </div>
}

@if (completadas.Any())
{
    <h5 class="fw-bold mb-3 text-secondary">
        <i class="bi bi-archive me-2"></i>Completadas / Fallidas
        <button class="btn btn-sm btn-link text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#completadasCollapse">
            <i class="bi bi-chevron-down"></i>
        </button>
    </h5>
    <div class="collapse show" id="completadasCollapse">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var mision in completadas)
            {
                @await Html.PartialAsync("_TarjetaMision", mision)
            }
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-secondary"></i>
        <p class="text-secondary mt-2">No tienes misiones aún. Crea tu primera misión.</p>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var spinner = document.getElementById('ep-spinner');
            if (spinner) spinner.style.display = 'none';
            cargarTodasSubTareas();
        });

        var editandoSubTareaId = null;

        function cargarTodasSubTareas() {
            document.querySelectorAll('.subtarea-list').forEach(function(list) {
                var misionId = list.getAttribute('data-mision-id');
                if (misionId) cargarSubTareas(misionId);
            });
        }

        function cargarSubTareas(misionId) {
            fetch('/api/misiones/' + misionId + '/sub-tareas')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.datos) renderizarSubTareas(misionId, data.datos);
                })
                .catch(function() {});
        }

        function renderizarSubTareas(misionId, subTareas) {
            var list = document.querySelector('.subtarea-list[data-mision-id="' + misionId + '"]');
            if (!list) return;
            list.innerHTML = '';
            var done = 0;

            subTareas.forEach(function(st) {
                if (st.estaCompletada) done++;
                var item = document.createElement('div');
                item.className = 'd-flex align-items-center gap-2 py-1 subtarea-item rounded px-1';
                item.dataset.id = st.id;

                var check = document.createElement('input');
                check.type = 'checkbox';
                check.className = 'form-check-input subtarea-check';
                check.checked = st.estaCompletada;
                check.addEventListener('change', function() {
                    if (this.checked) completarSubTarea(misionId, st.id);
                    else descompletarSubTarea(misionId, st.id);
                });

                var label = document.createElement('span');
                label.className = 'flex-grow-1 small subtarea-nombre' + (st.estaCompletada ? ' text-decoration-line-through text-secondary' : '');
                label.textContent = st.nombre;
                label.style.cursor = 'pointer';
                label.title = 'Editar nombre';
                label.addEventListener('dblclick', function() { iniciarEdicion(st.id, st.nombre, misionId); });

                var tiempo = document.createElement('small');
                tiempo.className = 'text-secondary subtarea-tiempo';
                tiempo.textContent = st.tiempoEnfoqueFormateado || '0s';
                tiempo.title = st.tiempoEnfoqueSegundos + ' segundos de enfoque';

                var delBtn = document.createElement('button');
                delBtn.className = 'btn btn-sm btn-link text-danger p-0 subtarea-delete';
                delBtn.innerHTML = '<i class="bi bi-trash"></i>';
                delBtn.addEventListener('click', function() { eliminarSubTarea(misionId, st.id); });

                item.appendChild(check);
                item.appendChild(label);
                item.appendChild(tiempo);
                item.appendChild(delBtn);
                list.appendChild(item);
            });

            actualizarContador(misionId, done, subTareas.length);
        }

        function actualizarContador(misionId, done, total) {
            var card = document.querySelector('[data-mision-id="' + misionId + '"]');
            if (!card) return;
            var toggle = card.querySelector('.subtarea-toggle');
            if (toggle) {
                toggle.querySelector('.subtarea-count').textContent = done + '/' + total;
            }
            var bar = card.querySelector('.subtarea-progress-bar');
            if (bar && total > 0) {
                bar.style.width = (done / total * 100) + '%';
                bar.setAttribute('aria-valuenow', done);
            }
        }

        function iniciarEdicion(id, nombreActual, misionId) {
            if (editandoSubTareaId === id) return;
            editandoSubTareaId = id;
            var item = document.querySelector('.subtarea-item[data-id="' + id + '"]');
            if (!item) return;
            var label = item.querySelector('.subtarea-nombre');
            var tiempo = item.querySelector('.subtarea-tiempo');
            var delBtn = item.querySelector('.subtarea-delete');

            label.style.display = 'none';
            if (tiempo) tiempo.style.display = 'none';
            if (delBtn) delBtn.style.display = 'none';

            var input = document.createElement('input');
            input.type = 'text';
            input.className = 'form-control form-control-sm flex-grow-1';
            input.value = nombreActual;
            input.maxLength = 200;
            item.insertBefore(input, tiempo);

            var confirmBtn = document.createElement('button');
            confirmBtn.className = 'btn btn-sm btn-success p-1 px-2';
            confirmBtn.innerHTML = '<i class="bi bi-check"></i>';
            item.insertBefore(confirmBtn, tiempo);

            var cancelBtn = document.createElement('button');
            cancelBtn.className = 'btn btn-sm btn-link text-secondary p-1 px-2';
            cancelBtn.innerHTML = '<i class="bi bi-x"></i>';
            item.insertBefore(cancelBtn, tiempo);

            input.focus();
            input.select();

            function cancelarEdicion() {
                label.style.display = '';
                if (tiempo) tiempo.style.display = '';
                if (delBtn) delBtn.style.display = '';
                input.remove();
                confirmBtn.remove();
                cancelBtn.remove();
                editandoSubTareaId = null;
            }

            function guardarEdicion() {
                var nuevoNombre = input.value.trim();
                if (nuevoNombre && nuevoNombre !== nombreActual) {
                    fetch('/api/misiones/' + misionId + '/sub-tareas/' + id, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ nombre: nuevoNombre, descripcion: null })
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data && data.exito !== false) cargarSubTareas(misionId);
                    })
                    .catch(function() {});
                }
                cancelarEdicion();
            }

            input.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') guardarEdicion();
                if (e.key === 'Escape') cancelarEdicion();
            });
            confirmBtn.addEventListener('click', guardarEdicion);
            cancelBtn.addEventListener('click', cancelarEdicion);
        }

        document.addEventListener('click', function(e) {
            var addBtn = e.target.closest('.subtarea-add');
            if (addBtn) {
                var container = addBtn.closest('.collapse, .ep-card');
                var input = container.querySelector('.subtarea-input');
                var list = container.querySelector('.subtarea-list');
                var misionId = list ? list.getAttribute('data-mision-id') : null;
                if (input && misionId && input.value.trim()) {
                    crearSubTarea(misionId, input.value.trim());
                    input.value = '';
                }
            }
        });

        function crearSubTarea(misionId, nombre) {
            fetch('/api/misiones/' + misionId + '/sub-tareas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre: nombre, descripcion: null })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data && data.exito !== false) cargarSubTareas(misionId);
            })
            .catch(function() {});
        }

        function completarSubTarea(misionId, id) {
            fetch('/api/misiones/' + misionId + '/sub-tareas/' + id + '/completar', { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.exito !== false) cargarSubTareas(misionId);
                })
                .catch(function() {});
        }

        function descompletarSubTarea(misionId, id) {
            fetch('/api/misiones/' + misionId + '/sub-tareas/' + id + '/descompletar', { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.exito !== false) cargarSubTareas(misionId);
                })
                .catch(function() {});
        }

        function eliminarSubTarea(misionId, id) {
            if (!confirm('\u00bfEliminar esta sub-tarea?')) return;
            fetch('/api/misiones/' + misionId + '/sub-tareas/' + id, { method: 'DELETE' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.exito !== false) cargarSubTareas(misionId);
                })
                .catch(function() {});
        }

        function confirmarCompletar(form) {
            if (!confirm('\u00bfEst\u00e1s seguro de completar esta misi\u00f3n? Esta acci\u00f3n se puede revertir despu\u00e9s.')) {
                return false;
            }
            return true;
        }

        function confirmarRevertir() {
            return confirm('\u00bfRevertir esta misi\u00f3n a En Progreso? Las sub-tareas completadas se marcar\u00e1n como pendientes.');
        }
    </script>
}
