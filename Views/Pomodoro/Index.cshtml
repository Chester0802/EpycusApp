@model EpycusApp.ViewModels.PomodoroIndexViewModel

@{
    ViewData["Title"] = "Pomodoro";
    var streakEmoji = Model.RachaActual > 0 ? "🔥" : "";
}

<div class="mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="ep-header-title d-flex align-items-center gap-2">Pomodoro <i class="bi bi-clock-history text-primary"></i></h1>
        <p class="ep-header-subtitle">Enfócate, mantén la concentración y conquista tus metas. <i class="bi bi-tree text-success"></i></p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        @if (Model.RachaActual > 0)
        {
            <span class="badge bg-warning bg-opacity-25 text-warning border border-warning px-3 py-2" title="Racha actual">
                🔥 @Model.RachaActual día(s)
            </span>
        }
        <a asp-action="Configuracion" class="btn btn-sm btn-ep-outline" title="Configuración">
            <i class="bi bi-sliders"></i>
        </a>
        <button class="btn btn-sm btn-ep-outline" id="btnFullscreen" onclick="alternarPantallaCompleta()" title="Pantalla completa (F)">
            <i class="bi bi-arrows-fullscreen"></i>
        </button>
        <button class="btn btn-sm btn-ep-outline" onclick="mostrarAyudaAtajos()" title="Atajos de teclado">
            <i class="bi bi-question-circle"></i>
        </button>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;" id="toastContainer"></div>

<!-- Modal sugerencia descanso largo -->
<div class="modal fade" id="modalDescansoLargo" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--ep-superficie); color: var(--text-primary);">
            <div class="modal-header border-secondary">
                <h5 class="modal-title"><i class="bi bi-tree text-success me-2"></i>Descanso largo recomendado</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Has completado varios ciclos seguidos. Tu cerebro necesita una pausa más larga para recuperarse y mantener la productividad.</p>
                <p class="text-secondary small">Un descanso largo de <strong id="modalDescansoDuracion">15</strong> minutos te ayudará a recargar energías.</p>
                <div id="pausaActivaContent" class="alert alert-info bg-transparent border-info text-info small mt-3" style="display:none;"></div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-sm btn-ep-outline" data-bs-dismiss="modal" onclick="window._modalHandled=true; establecerModo('corto'); alternarTimer();">Descanso corto</button>
                <button type="button" class="btn btn-sm btn-success" data-bs-dismiss="modal" id="btnIniciarDescansoLargo">Iniciar descanso largo</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal sesion activa -->
<div class="modal fade" id="modalSesionActiva" tabindex="-1" data-bs-backdrop="static" data-bs-focus="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--ep-superficie); color: var(--text-primary);">
            <div class="modal-header border-secondary">
                <h5 class="modal-title"><i class="bi bi-clock-history text-primary me-2"></i>Sesión activa</h5>
            </div>
            <div class="modal-body">
                <p>Tienes una sesión de Pomodoro sin finalizar. ¿Qué deseas hacer?</p>
                <p class="text-secondary small" id="modalSesionInfo"></p>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-sm btn-danger" id="btnSesionReiniciar" onclick="reiniciarSesionActiva()">Reiniciar</button>
                <button type="button" class="btn btn-sm btn-success" id="btnSesionContinuar" onclick="continuarSesionActiva()">Continuar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal meta cumplida -->
<div class="modal fade" id="modalMetaCumplida" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--ep-superficie); color: var(--text-primary);">
            <div class="modal-header border-secondary">
                <h5 class="modal-title"><i class="bi bi-trophy text-warning me-2"></i>¡Meta diaria cumplida!</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-center py-3" style="font-size: 1.2rem;">🎉 ¡Has alcanzado tu meta de <strong id="modalMetaNumero">0</strong> ciclos hoy!</p>
                <p class="text-secondary text-center small">Sigue así, cada ciclo te acerca más a tus objetivos.</p>
            </div>
            <div class="modal-footer border-secondary justify-content-center">
                <button type="button" class="btn btn-sm btn-success" data-bs-dismiss="modal">¡Seguir avanzando!</button>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-7 mb-4">
        <div class="ep-card text-center" style="padding: 2.5rem 1.5rem;" id="pomodoroCard">

            <!-- Tabs de Modos -->
            <div class="ep-pomodoro-tabs mb-4" id="modeTabs">
                <div class="ep-pomodoro-tab active" data-mode="enfoque" onclick="establecerModo('enfoque')">
                    <i class="bi bi-bullseye"></i> Enfoque
                </div>
                <div class="ep-pomodoro-tab" data-mode="corto" onclick="establecerModo('corto')">
                    <i class="bi bi-cup-hot"></i> Descanso corto
                </div>
                <div class="ep-pomodoro-tab" data-mode="largo" onclick="establecerModo('largo')">
                    <i class="bi bi-tree"></i> Descanso largo
                </div>
                <div class="ep-pomodoro-tab" data-mode="personalizado" onclick="establecerModo('personalizado')">
                    <i class="bi bi-gear"></i> Personalizado
                </div>
            </div>

            <!-- Círculo del Temporizador con SVG -->
            <div class="ep-pomodoro-timer-wrapper">
                <div class="ep-pomodoro-ring" id="timerRing">
                    <svg class="ep-pomodoro-svg" viewBox="0 0 100 100">
                        <circle class="ep-pomodoro-svg-bg" cx="50" cy="50" r="45" />
                        <circle class="ep-pomodoro-svg-progress" id="progressCircle" cx="50" cy="50" r="45"
                            stroke-dasharray="282.74" stroke-dashoffset="0" />
                    </svg>
                    <div class="ep-pomodoro-ring-content" style="position:relative;">
                        <div class="mb-2" style="font-size: 1.5rem;"><i class="bi bi-clock"></i></div>
                        <div class="position-absolute top-0 end-0" id="dndIndicator" style="display:none;">
                            <span class="badge bg-danger bg-opacity-75" style="font-size:0.55rem;"><i class="bi bi-moon"></i> No molestar</span>
                        </div>
                        <div class="ep-pomodoro-time" id="timerDisplay">25:00</div>
                        <div class="ep-pomodoro-label" id="timerLabel">Tiempo de enfoque</div>
                        <div class="ep-pomodoro-ciclo" id="cicloIndicator"></div>
                    </div>
                </div>
            </div>

            <!-- Controles -->
            <div class="ep-pomodoro-controls mb-5">
                <button class="ep-btn-play" id="btnPlayPause" onclick="alternarTimer()">
                    <i class="bi bi-play-fill me-2" id="playIcon"></i> <span id="playText">Iniciar</span>
                </button>
                <button class="ep-btn-icon" id="btnReset" onclick="reiniciarTimer()" title="Reiniciar (R)">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </button>
                <button class="ep-btn-icon" id="btnSkip" onclick="saltarCiclo()" title="Saltar ciclo" style="display:none;">
                    <i class="bi bi-skip-forward-fill"></i>
                </button>
                <button class="ep-btn-icon" id="btnFinalizar" onclick="finalizarSesion()" title="Finalizar sesión" style="display:none;">
                    <i class="bi bi-check2-square"></i>
                </button>
            </div>

            <!-- Controles rápidos -->
            <div class="row text-start border-top border-secondary pt-4 mt-2">
                <div class="col-md-3 mb-3 mb-md-0">
                    <label class="text-secondary small mb-1 d-block" title="Número de Pomodoros (sesiones de enfoque) que planeas completar hoy">Meta diaria <i class="bi bi-info-circle"></i></label>
                    <div class="d-flex align-items-center bg-transparent border border-secondary rounded p-1" style="width: fit-content;">
                        <span class="px-3 fw-bold" id="ciclosDisplay">1</span>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary rounded-circle" style="width:44px;height:44px;padding:0;font-size:1.2rem;" onclick="ajustarCiclos(-1)">-</button>
                            <button class="btn btn-sm btn-outline-secondary rounded-circle" style="width:44px;height:44px;padding:0;font-size:1.2rem;" onclick="ajustarCiclos(1)">+</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3 mb-md-0">
                    <label class="text-secondary small mb-1 d-block">Sonido</label>
                    <select class="form-select form-select-sm bg-transparent border-secondary" id="configSonido" style="color: var(--text-primary);">
                        <option value="campana" selected>🔔 Campana</option>
                        <option value="digital">🔊 Digital</option>
                        <option value="naturaleza">🌿 Naturaleza</option>
                        <option value="silencio">🔇 Silencio</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3 mb-md-0">
                    <label class="text-secondary small mb-1 d-block">Volumen</label>
                    <input type="range" class="form-range" id="configVolumen" min="0" max="100" value="@(Model?.Configuracion?.Volumen ?? 100)" style="width:100%;" />
                </div>
                <div class="col-md-3 mb-3 mb-md-0 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="chkTicTac" @(Model?.Configuracion?.TicTacActivo == true ? "checked" : "") />
                        <label class="form-check-label small" for="chkTicTac">Tic-tac</label>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="col-lg-5">

        <!-- Meta diaria -->
        @if (Model?.Configuracion?.MetaDiariaCiclos > 0)
        {
            <div class="ep-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-bold mb-0" title="Número de Pomodoros (sesiones de enfoque) que planeas completar hoy">Meta diaria <i class="bi bi-info-circle"></i></h6>
                    <span class="text-secondary small" id="metaText">@Model.EstadisticasHoy.CiclosCompletados / @Model.Configuracion.MetaDiariaCiclos</span>
                </div>
                <div class="progress" style="height: 8px; background: var(--ep-superficie-2);">
                    <div class="progress-bar bg-success" id="metaBar" role="progressbar"
                        style="width: @(Model.Configuracion.MetaDiariaCiclos > 0 ? Math.Min(100, (double)Model.EstadisticasHoy.CiclosCompletados / Model.Configuracion.MetaDiariaCiclos * 100) : 0)%"></div>
                </div>
            </div>
        }

        <!-- Resumen de Hoy -->
        <div class="ep-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Resumen de hoy</h6>
                @if (Model?.RachaActual > 0)
                {
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">
                        🔥 Racha: @Model?.RachaActual
                    </span>
                }
            </div>

            <div id="ep-spinner" class="ep-spinner-overlay"><div class="ep-spinner"></div><span class="ms-2">Cargando estadísticas...</span></div>

            <div class="row g-2 pomodoro-stats" id="pomodoroStats">
                <div class="col-6">
                    <div class="border border-secondary rounded p-3 text-center" style="background: var(--ep-superficie-2);">
                        <i class="bi bi-clock text-primary fs-4"></i>
                        <h4 class="fw-bold mt-1 mb-0" id="statCiclos">@(Model?.EstadisticasHoy.CiclosCompletados ?? 0)</h4>
                        <small class="text-secondary" style="font-size:0.7rem;">Ciclos completados</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border border-secondary rounded p-3 text-center" style="background: var(--ep-superficie-2);">
                        <i class="bi bi-fire text-warning fs-4"></i>
                        <h4 class="fw-bold mt-1 mb-0" id="statMinutos">@(Model?.EstadisticasHoy.MinutosEnfocados ?? 0)</h4>
                        <small class="text-secondary" style="font-size:0.7rem;">Minutos enfocados</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border border-secondary rounded p-3 text-center" style="background: var(--ep-superficie-2);">
                        <i class="bi bi-graph-up-arrow text-success fs-4"></i>
                        <h4 class="fw-bold mt-1 mb-0" id="statXpGanado">@(Model?.EstadisticasHoy.XpGanado ?? 0)</h4>
                        <small class="text-secondary" style="font-size:0.7rem;">XP ganado</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="border border-secondary rounded p-3 text-center" style="background: var(--ep-superficie-2);">
                        <i class="bi bi-bullseye text-info fs-4"></i>
                        <h4 class="fw-bold mt-1 mb-0" id="statMisiones">@(Model?.EstadisticasHoy.MisionesCompletadas ?? 0)</h4>
                        <small class="text-secondary" style="font-size:0.7rem;">Misiones Completadas</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráfico semanal -->
        <div class="ep-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Actividad semanal</h6>
            </div>
            <div class="d-flex justify-content-around align-items-end" style="height: 80px;" id="weeklyChart">
                @if (Model?.EstadisticasSemanales != null)
                {
                    var maxCiclos = Model.EstadisticasSemanales.Max(s => s.Ciclos);
                    if (maxCiclos == 0) maxCiclos = 1;
                    foreach (var dia in Model.EstadisticasSemanales)
                    {
                        var altura = (int)((double)dia.Ciclos / maxCiclos * 60);
                        <div class="text-center" style="flex:1;">
                            <div class="bg-primary bg-opacity-50 rounded" style="height:@(altura)px; width:16px; margin:0 auto; transition: height 0.3s;" title="@dia.Ciclos ciclos"></div>
                            <small class="text-secondary" style="font-size:0.6rem;">@dia.Fecha</small>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Tareas de enfoque -->
        <div class="ep-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Tareas de enfoque</h6>
                <span class="text-muted small">Selecciona una para enfocarte</span>
            </div>

            <div id="taskList">
                @if (Model != null && Model.TareasEnfoque != null && Model.TareasEnfoque.Any())
                {
                    foreach (var tarea in Model.TareasEnfoque)
                    {
                        string iconClass = tarea.Tipo == "Habito" ? "bi-journal-check" : "bi-bullseye";
                        string colorClass = tarea.Tipo == "Habito" ? "text-primary" : "text-danger";

                        <div class="ep-task-item cursor-pointer" onclick="seleccionarTarea(this, '@tarea.Id', '@tarea.Tipo')">
                            <div class="ep-task-check"><i class="bi bi-check"></i></div>
                            <div class="flex-grow-1" style="font-size: 0.9rem;">
                                <i class="bi @iconClass @colorClass me-2"></i> @tarea.Nombre
                                <span class="ep-task-tag">@tarea.CategoriaNombre</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info bg-transparent border-info text-info small">
                        No tienes hábitos ni misiones marcados para usar Pomodoro. Puedes activarlos editándolos en sus respectivas pantallas.
                    </div>
                }
            </div>

            <div id="subtareaSelector" class="mt-2 mb-2" style="display:none;">
                <label class="text-secondary small mb-1">Sub-tarea (opcional):</label>
                <select class="form-select form-select-sm bg-transparent border-secondary" id="subtareaSelect" style="color: var(--text-primary);">
                    <option value="">-- Sin sub-tarea --</option>
                </select>
            </div>

            <div class="mt-3 p-3 rounded" style="background: var(--warning-bg); border-left: 3px solid var(--warning); font-size: 0.85rem;" id="consejoContainer">
                <i class="bi bi-lightbulb text-warning me-2"></i> <span id="consejoTexto">Una tarea por ciclo. Concéntrate al 100%.</span> <i class="bi bi-tree text-success"></i>
            </div>
        </div>

        <!-- Historial de hoy -->
        <div class="ep-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Historial de hoy</h6>
            </div>

            <div class="border-start border-2 border-secondary ms-2 ps-3" id="historialList">
                @if (Model != null && Model.HistorialHoy != null && Model.HistorialHoy.Any())
                {
                    foreach (var sesion in Model.HistorialHoy)
                    {
                        bool esEnfoque = sesion.Tipo == "Enfoque" || sesion.Tipo == "Personalizado";
                        string tipo = sesion.Tipo switch
                        {
                            "Enfoque" => "Enfoque",
                            "Personalizado" => "Personalizado",
                            "DescansoCorto" => "Descanso corto",
                            "DescansoLargo" => "Descanso largo",
                            _ => sesion.XpOtorgado > 0 ? "Enfoque" : "Descanso"
                        };
                        string tiempoTxt = sesion.FechaFin.HasValue
                            ? $"{(int)(sesion.FechaFin.Value - sesion.FechaInicio).TotalMinutes} min"
                            : "0 min";
                        string iconClass = esEnfoque ? "bi-check-circle text-success" : "bi-cup-hot text-warning";
                        string badgeBg = esEnfoque ? "var(--success-bg)" : "var(--warning-bg)";
                        string badgeColor = esEnfoque ? "var(--success)" : "var(--warning)";
                        string badgeBorder = esEnfoque ? "var(--success)" : "var(--warning)";
                        string badgeText = esEnfoque ? "Completado" : "Descanso";

                        <div class="position-relative mb-3 ps-4">
                            <i class="bi @iconClass position-absolute" style="left: 0; top: 0px; background: var(--ep-superficie); padding-bottom: 5px;"></i>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <div>
                                    <span class="fw-bold">@tipo</span> <span class="text-secondary ms-2">@tiempoTxt</span>
                                </div>
                                <span class="badge bg-opacity-25" style="background: @badgeBg; color: @badgeColor; border: 1px solid @badgeBorder;">@badgeText</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-secondary small fst-italic no-sesiones-msg">Aún no hay sesiones registradas hoy.</div>
                }
            </div>
        </div>

    </div>
</div>

<!-- Modal atajos teclado -->
<div class="modal fade" id="modalAtajos" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="background: var(--ep-superficie); color: var(--text-primary);">
            <div class="modal-header border-secondary">
                <h5 class="modal-title"><i class="bi bi-keyboard me-2"></i>Atajos de teclado</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-between mb-2"><span>Espacio</span><kbd class="bg-dark text-light px-2 rounded">Play / Pausa</kbd></div>
                <div class="d-flex justify-content-between mb-2"><span>R</span><kbd class="bg-dark text-light px-2 rounded">Reiniciar</kbd></div>
                <div class="d-flex justify-content-between mb-2"><span>1-4</span><kbd class="bg-dark text-light px-2 rounded">Cambiar modo</kbd></div>
                <div class="d-flex justify-content-between mb-2"><span>F</span><kbd class="bg-dark text-light px-2 rounded">Pantalla completa</kbd></div>
                <div class="d-flex justify-content-between"><span>S</span><kbd class="bg-dark text-light px-2 rounded">Saltar ciclo</kbd></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const CONFIGURACION = {
            enfoque: @(Model?.Configuracion?.TiempoEstudioMin ?? 25) * 60,
            corto: @(Model?.Configuracion?.TiempoDescansoMin ?? 5) * 60,
            largo: @(Model?.Configuracion?.TiempoDescansoLargoMin ?? 15) * 60,
            personalizado: @(Model?.Configuracion?.ModoPersonalizadoMin ?? 25) * 60,
            ciclosAntesLargo: @(Model?.Configuracion?.CiclosAntesDescansoLargo ?? 4),
            metaDiaria: @(Model?.Configuracion?.MetaDiariaCiclos ?? 0),
            autoIniciarDescanso: @(Model?.Configuracion?.AutoIniciarDescanso == true ? "true" : "false"),
            autoIniciarEnfoque: @(Model?.Configuracion?.AutoIniciarEnfoque == true ? "true" : "false"),
            vibracionActiva: @(Model?.Configuracion?.VibracionActiva == true ? "true" : "false"),
            notificacionDesktop: @(Model?.Configuracion?.NotificacionDesktop == true ? "true" : "false"),
        };

        let metaDiariaValue = CONFIGURACION.metaDiaria > 0 ? CONFIGURACION.metaDiaria : 4;
        document.getElementById('ciclosDisplay').innerText = metaDiariaValue;

        let estadoTimer = {
            modo: 'enfoque',
            tiempoRestante: CONFIGURACION.enfoque,
            tiempoTotal: CONFIGURACION.enfoque,
            estaCorriendo: false,
            idIntervalo: null,
            sesionId: null,
            tareaSeleccionadaId: null,
            tareaSeleccionadaTipo: null,
            tareaSeleccionadaNombre: null,
            subTareaId: null,
            subTareaNombre: null,
            ciclosCompletados: parseInt(document.getElementById('statCiclos').innerText) || 0,
            minutosTotales: parseInt(document.getElementById('statMinutos').innerText) || 0,
            xpTotal: parseInt(document.getElementById('statXpGanado').innerText) || 0,
            ultimoTick: null,
            procesandoCompletado: false
        };

        const elDisplayTimer = document.getElementById('timerDisplay');
        const etiquetaTimer = document.getElementById('timerLabel');
        const anilloTimer = document.getElementById('timerRing');
        const btnPlayPausa = document.getElementById('btnPlayPause');
        const iconoPlay = document.getElementById('playIcon');
        const textoPlay = document.getElementById('playText');
        const displayCiclos = document.getElementById('ciclosDisplay');
        const circuloProgreso = document.getElementById('progressCircle');
        const btnSaltar = document.getElementById('btnSkip');
        const CIRCUNFERENCIA = 2 * Math.PI * 45;

        let contextoAudio = null;

        function obtenerContextoAudio() {
            if (!contextoAudio) {
                contextoAudio = new (window.AudioContext || window.webkitAudioContext)();
            }
            return contextoAudio;
        }

        function reproducirSonido(tipo) {
            const sonido = document.getElementById('configSonido').value;
            if (sonido === 'silencio') return;
            const volumen = parseInt(document.getElementById('configVolumen').value) / 100;
            if (volumen === 0) return;

            try {
                const ctx = obtenerContextoAudio();
                const gain = ctx.createGain();
                gain.connect(ctx.destination);
                gain.gain.value = volumen * 0.3;

                if (sonido === 'campana' || tipo === 'tictac') {
                    const osc = ctx.createOscillator();
                    const freq = tipo === 'tictac' ? 800 : 523.25;
                    osc.type = tipo === 'tictac' ? 'sine' : 'sine';
                    osc.frequency.value = freq;
                    osc.connect(gain);
                    osc.start();
                    osc.stop(ctx.currentTime + (tipo === 'tictac' ? 0.05 : 0.3));
                } else if (sonido === 'digital') {
                    const osc = ctx.createOscillator();
                    osc.type = 'square';
                    osc.frequency.value = 880;
                    osc.connect(gain);
                    osc.start();
                    osc.stop(ctx.currentTime + 0.15);
                } else if (sonido === 'naturaleza') {
                    const bufferSize = ctx.sampleRate * 0.5;
                    const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
                    const data = buffer.getChannelData(0);
                    for (let i = 0; i < bufferSize; i++) {
                        data[i] = (Math.random() * 2 - 1) * (1 - i / bufferSize);
                    }
                    const noise = ctx.createBufferSource();
                    noise.buffer = buffer;
                    noise.connect(gain);
                    noise.start();
                }
            } catch(e) { /* fallback silencioso */ }
        }

        let intervaloTicTac = null;

        function iniciarTicTac() {
            detenerTicTac();
            const ticActivo = document.getElementById('chkTicTac').checked;
            if (!ticActivo || !estadoTimer.estaCorriendo) return;

            intervaloTicTac = setInterval(() => {
                if (estadoTimer.modo === 'enfoque') {
                    reproducirSonido('tictac');
                }
            }, 1000);
        }

        function detenerTicTac() {
            if (intervaloTicTac) {
                clearInterval(intervaloTicTac);
                intervaloTicTac = null;
            }
        }

        function notificar(titulo, mensaje) {
            if (CONFIGURACION.notificacionDesktop && 'Notification' in window) {
                if (Notification.permission === 'granted') {
                    new Notification(titulo, { body: mensaje, icon: '/favicon.ico' });
                } else if (Notification.permission !== 'denied') {
                    Notification.requestPermission();
                }
            }
            if (CONFIGURACION.vibracionActiva && navigator.vibrate) {
                navigator.vibrate([100, 50, 100]);
            }
        }

        function mostrarToast(mensaje, tipo) {
            tipo = tipo || 'danger';
            var container = document.getElementById('toastContainer');
            var toast = document.createElement('div');
            toast.className = 'toast align-items-center text-bg-' + tipo + ' border-0 show';
            toast.setAttribute('role', 'alert');
            toast.innerHTML = '<div class="d-flex"><div class="toast-body">' + mensaje + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>';
            container.appendChild(toast);
            setTimeout(function() { toast.remove(); }, 5000);
        }

        function mostrarError(mensaje) { mostrarToast(mensaje, 'danger'); }
        function mostrarExito(mensaje) { mostrarToast(mensaje, 'success'); }
        function mostrarInfo(mensaje) { mostrarToast(mensaje, 'info'); }

        async function reiniciarSesionActiva() {
            if (estadoTimer.sesionId) {
                var idSesion = estadoTimer.sesionId;
                estadoTimer.sesionId = null;
                try {
                    var resp = await fetch(`/api/v1/pomodoro/${idSesion}/cancelar`, { method: 'POST' });
                    if (!resp.ok) {
                        estadoTimer.sesionId = idSesion;
                        mostrarError("No se pudo cancelar la sesión anterior.");
                        return;
                    }
                } catch(e) {
                    estadoTimer.sesionId = idSesion;
                    mostrarError("Error de conexión al cancelar la sesión.");
                    return;
                }
            }
            document.activeElement.blur();
            var modal = bootstrap.Modal.getInstance(document.getElementById('modalSesionActiva'));
            if (modal) modal.hide();
            estadoTimer.ciclosCompletados = 0;
            estadoTimer.minutosTotales = 0;
            estadoTimer.xpTotal = 0;
            document.getElementById('statCiclos').innerText = '0';
            document.getElementById('statMinutos').innerText = '0';
            document.getElementById('statXpGanado').innerText = '0';
            establecerModo('enfoque');
            mostrarExito('Sesión reiniciada. ¡Nuevo comienzo!');
        }

        function continuarSesionActiva() {
            document.activeElement.blur();
            var modal = bootstrap.Modal.getInstance(document.getElementById('modalSesionActiva'));
            if (modal) modal.hide();
            if (estadoTimer.ciclosCompletados > 0) {
                document.getElementById('statCiclos').innerText = estadoTimer.ciclosCompletados;
            }
            mostrarExito('Sesión restaurada. Puedes continuar.');
        }

        function guardarEstadoTimer() {
            try {
                var estado = {
                    modo: estadoTimer.modo,
                    sesionId: estadoTimer.sesionId,
                    tareaSeleccionadaId: estadoTimer.tareaSeleccionadaId,
                    tareaSeleccionadaTipo: estadoTimer.tareaSeleccionadaTipo,
                    tareaSeleccionadaNombre: estadoTimer.tareaSeleccionadaNombre,
                    subTareaId: estadoTimer.subTareaId,
                    subTareaNombre: estadoTimer.subTareaNombre,
                    ciclosCompletados: estadoTimer.ciclosCompletados,
                    minutosTotales: estadoTimer.minutosTotales,
                    xpTotal: estadoTimer.xpTotal,
                    metaDiaria: metaDiariaValue,
                    tiempoRestante: estadoTimer.tiempoRestante,
                    tiempoTotal: estadoTimer.tiempoTotal,
                    estaCorriendo: estadoTimer.estaCorriendo
                };
                if (estadoTimer.estaCorriendo) {
                    estado.finEn = Date.now() + estadoTimer.tiempoRestante * 1000;
                }
                localStorage.setItem('epycus_pomodoro', JSON.stringify(estado));
            } catch(e) {}
        }

        function restaurarEstadoTimer() {
            try {
                var saved = localStorage.getItem('epycus_pomodoro');
                if (!saved) return;
                var estado = JSON.parse(saved);
                if (!estado || !estado.modo) return;

                var modoValido = CONFIGURACION[estado.modo] != null;
                if (!modoValido) return;

                estadoTimer.modo = estado.modo;
                estadoTimer.tiempoTotal = CONFIGURACION[estado.modo];
                estadoTimer.sesionId = estado.sesionId || null;
                estadoTimer.tareaSeleccionadaId = estado.tareaSeleccionadaId || null;
                estadoTimer.tareaSeleccionadaTipo = estado.tareaSeleccionadaTipo || null;
                estadoTimer.tareaSeleccionadaNombre = estado.tareaSeleccionadaNombre || null;
                estadoTimer.subTareaId = estado.subTareaId || null;
                estadoTimer.subTareaNombre = estado.subTareaNombre || null;
                estadoTimer.ciclosCompletados = estado.ciclosCompletados || 0;
                estadoTimer.minutosTotales = estado.minutosTotales || 0;
                estadoTimer.xpTotal = estado.xpTotal || 0;
                metaDiariaValue = estado.metaDiaria || (CONFIGURACION.metaDiaria > 0 ? CONFIGURACION.metaDiaria : 4);

                if (estado.estaCorriendo && estado.finEn) {
                    var remaining = Math.max(0, Math.floor((estado.finEn - Date.now()) / 1000));
                    estadoTimer.tiempoRestante = Math.min(remaining, estadoTimer.tiempoTotal);
                    if (remaining > 0) {
                        setTimeout(function() { alternarTimer(); }, 300);
                    }
                } else {
                    estadoTimer.tiempoRestante = estado.tiempoRestante != null
                        ? Math.min(estado.tiempoRestante, estadoTimer.tiempoTotal)
                        : estadoTimer.tiempoTotal;
                }

                document.getElementById('statCiclos').innerText = estadoTimer.ciclosCompletados;
                document.getElementById('statMinutos').innerText = estadoTimer.minutosTotales;
                document.getElementById('statXpGanado').innerText = estadoTimer.xpTotal;
                displayCiclos.innerText = metaDiariaValue;
                if (CONFIGURACION.metaDiaria > 0) {
                    var metaBarEl = document.getElementById('metaBar');
                    var metaTextEl = document.getElementById('metaText');
                    if (metaBarEl && metaTextEl) {
                        var pctRestore = Math.min(100, (estadoTimer.ciclosCompletados / CONFIGURACION.metaDiaria) * 100);
                        metaBarEl.style.width = pctRestore + '%';
                        metaTextEl.innerText = estadoTimer.ciclosCompletados + ' / ' + CONFIGURACION.metaDiaria;
                    }
                }
                establecerModo(estado.modo);

                localStorage.removeItem('epycus_pomodoro');
            } catch(e) {}
        }

        document.addEventListener('beforeunload', function() {
            guardarEstadoTimer();
        });

        setTimeout(function() {
            var sp = document.getElementById('ep-spinner');
            if (sp && sp.style.display !== 'none') { sp.style.display = 'none'; }
        }, 8000);

        document.addEventListener('DOMContentLoaded', function() {
            var spinner = document.getElementById('ep-spinner');
            if (spinner) spinner.style.display = 'none';
            if ('Notification' in window && Notification.permission === 'default') {
                Notification.requestPermission();
            }

            restaurarEstadoTimer();

            // NF-20: Sincronización entre pestañas vía BroadcastChannel
            try {
                var bc = new BroadcastChannel('epycus_pomodoro');
                bc.onmessage = function(ev) {
                    var msg = ev.data;
                    if (!msg || !msg.type) return;
                    switch (msg.type) {
                        case 'timer_start':
                        case 'timer_pause':
                            if (msg.modo) estadoTimer.modo = msg.modo;
                            estadoTimer.tiempoRestante = msg.tiempoRestante;
                            estadoTimer.tiempoTotal = msg.tiempoTotal;
                            estadoTimer.ciclosCompletados = msg.ciclos;
                            if (msg.type === 'timer_start' && !estadoTimer.estaCorriendo) {
                                estadoTimer.estaCorriendo = true;
                            } else if (msg.type === 'timer_pause' && estadoTimer.estaCorriendo) {
                                estadoTimer.estaCorriendo = false;
                            }
                            actualizarUI();
                            break;
                        case 'timer_complete':
                            estadoTimer.ciclosCompletados = msg.ciclos;
                            document.getElementById('statCiclos').innerText = msg.ciclos;
                            actualizarUI();
                            break;
                        case 'mode_change':
                            estadoTimer.modo = msg.modo;
                            estadoTimer.tiempoRestante = msg.tiempoRestante;
                            estadoTimer.tiempoTotal = msg.tiempoTotal;
                            estadoTimer.estaCorriendo = false;
                            if (msg.ciclos !== undefined) estadoTimer.ciclosCompletados = msg.ciclos;
                            establecerModo(msg.modo);
                            break;
                    }
                };
                window._broadcastChannel = bc;
            } catch(e) { /* BroadcastChannel no soportado */ }

            fetch('/api/v1/pomodoro/tip-aleatorio')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.datos && data.datos.consejo) {
                        document.getElementById('consejoTexto').innerText = data.datos.consejo;
                    }
                })
                .catch(function() {});

            var volSlider = document.getElementById('configVolumen');
            var volGuardado = localStorage.getItem('epycus_pomodoro_volumen');
            if (volGuardado !== null) { volSlider.value = volGuardado; }
            volSlider.addEventListener('change', function() {
                localStorage.setItem('epycus_pomodoro_volumen', this.value);
            });

            document.getElementById('chkTicTac').addEventListener('change', function() {
                if (!this.checked && intervaloTicTac) {
                    detenerTicTac();
                } else if (this.checked && estadoTimer.estaCorriendo && estadoTimer.modo === 'enfoque') {
                    iniciarTicTac();
                }
            });

            if (!estadoTimer.sesionId) {
                fetch('/api/v1/pomodoro/sesion-activa')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (data && data.datos && data.datos.activa && !estadoTimer.sesionId) {
                            estadoTimer.sesionId = data.datos.sesionId;
                            estadoTimer.ciclosCompletados = data.datos.ciclosCompletados || 0;
                            document.getElementById('statCiclos').innerText = estadoTimer.ciclosCompletados;
                            document.getElementById('modalSesionInfo').innerText = estadoTimer.ciclosCompletados > 0
                                ? estadoTimer.ciclosCompletados + ' ciclo(s) completado(s) en la sesión anterior.'
                                : 'Sesión iniciada pero sin ciclos completados aún.';
                            var modalActiva = bootstrap.Modal.getOrCreateInstance(document.getElementById('modalSesionActiva'));
                            modalActiva.show();
                        }
                    })
                    .catch(function() {});
            }
        });

        function formatearTiempo(seconds) {
            // Nunca mostrar tiempo negativo (ej. "-1:-1"): si algo deja tiempoRestante sin
            // resetear tras completar un ciclo (fallo de red, modal que no se muestra en
            // móvil, etc.), como mínimo se ve "00:00" en vez de un número que decrece sin fin.
            const safeSeconds = Math.max(0, Math.floor(seconds) || 0);
            const m = Math.floor(safeSeconds / 60).toString().padStart(2, '0');
            const s = (safeSeconds % 60).toString().padStart(2, '0');
            return `${m}:${s}`;
        }

        function actualizarUI() {
            elDisplayTimer.innerText = formatearTiempo(estadoTimer.tiempoRestante);
            const progress = estadoTimer.tiempoTotal > 0 ? (estadoTimer.tiempoRestante / estadoTimer.tiempoTotal) * CIRCUNFERENCIA : 0;
            circuloProgreso.setAttribute('stroke-dashoffset', progress);
            actualizarIndicadorCiclo();
        }

        function actualizarIndicadorCiclo() {
            var el = document.getElementById('cicloIndicator');
            if (!el) return;
            if (estadoTimer.modo === 'enfoque' || estadoTimer.modo === 'personalizado') {
                var total = metaDiariaValue || CONFIGURACION.metaDiaria || 4;
                el.innerText = 'Sesión ' + (estadoTimer.ciclosCompletados + 1) + ' / ' + total;
            } else {
                el.innerText = '';
            }
        }

        function broadcastMensaje(tipo, datos) {
            try {
                if (window._broadcastChannel) {
                    window._broadcastChannel.postMessage(Object.assign({ type: tipo }, datos));
                }
            } catch(e) {}
        }

        function establecerModo(modo) {
            if (estadoTimer.estaCorriendo) {
                if (!confirm("Hay un temporizador en curso. ¿Deseas cambiar de modo y detenerlo?")) return;
                detenerTimer();
            }

            estadoTimer.modo = modo;
            estadoTimer.tiempoRestante = CONFIGURACION[modo] || CONFIGURACION.enfoque;
            estadoTimer.tiempoTotal = CONFIGURACION[modo] || CONFIGURACION.enfoque;
            btnSaltar.style.display = (modo === 'enfoque' || modo === 'personalizado') ? 'inline-flex' : 'none';
            document.getElementById('btnFinalizar').style.display = ((modo === 'enfoque' || modo === 'personalizado') && estadoTimer.sesionId) ? 'inline-flex' : 'none';
            actualizarUI();

            if (estadoTimer.estaCorriendo) {
                broadcastMensaje('mode_change', { modo: modo, tiempoRestante: estadoTimer.tiempoRestante, tiempoTotal: estadoTimer.tiempoTotal, ciclos: estadoTimer.ciclosCompletados });
            }

            document.querySelectorAll('.ep-pomodoro-tab').forEach(tab => {
                tab.classList.remove('active', 'descanso');
                if (tab.dataset.mode === modo) {
                    tab.classList.add('active');
                    if (modo !== 'enfoque') tab.classList.add('descanso');
                }
            });

            if (modo === 'enfoque' || modo === 'personalizado') {
                anilloTimer.classList.remove('descanso');
                btnPlayPausa.classList.remove('descanso');
                etiquetaTimer.innerText = modo === 'personalizado' ? 'Modo personalizado' : 'Tiempo de enfoque';
            } else {
                anilloTimer.classList.add('descanso');
                btnPlayPausa.classList.add('descanso');
                etiquetaTimer.innerText = modo === 'corto' ? 'Descanso corto' : 'Descanso largo';
            }
        }

        function ajustarCiclos(val) {
            let n = metaDiariaValue + val;
            if (n >= 1 && n <= 50) {
                metaDiariaValue = n;
                displayCiclos.innerText = n;
            }
        }

        function seleccionarTarea(element, id, tipo) {
            if (element && estadoTimer.tareaSeleccionadaId === id && estadoTimer.tareaSeleccionadaTipo === tipo) {
                element.querySelector('.ep-task-check').classList.remove('checked');
                element.style.borderColor = 'transparent';
                element.style.borderWidth = '0';
                element.style.borderStyle = 'none';
                estadoTimer.tareaSeleccionadaId = null;
                estadoTimer.tareaSeleccionadaTipo = null;
                estadoTimer.tareaSeleccionadaNombre = null;
                estadoTimer.subTareaId = null;
                estadoTimer.subTareaNombre = null;
                ocultarSelectorSubTarea();
                actualizarInfoTarea();
                return;
            }

            document.querySelectorAll('.ep-task-check').forEach(el => el.classList.remove('checked'));
            document.querySelectorAll('.ep-task-item').forEach(el => {
                el.style.borderColor = 'transparent';
                el.style.borderWidth = '0';
                el.style.borderStyle = 'none';
            });

            if (element) {
                element.querySelector('.ep-task-check').classList.add('checked');
                element.style.borderColor = 'var(--ep-primario)';
                element.style.borderWidth = '1px';
                element.style.borderStyle = 'solid';
                estadoTimer.tareaSeleccionadaId = id;
                estadoTimer.tareaSeleccionadaTipo = tipo;
                estadoTimer.tareaSeleccionadaNombre = element.querySelector('.flex-grow-1')?.textContent?.trim() || '';
                estadoTimer.subTareaId = null;
                estadoTimer.subTareaNombre = null;

                if (tipo === 'Mision') {
                    cargarSubTareasDeMision(id);
                } else {
                    ocultarSelectorSubTarea();
                }
            } else {
                estadoTimer.tareaSeleccionadaId = null;
                estadoTimer.tareaSeleccionadaTipo = null;
                estadoTimer.tareaSeleccionadaNombre = null;
                estadoTimer.subTareaId = null;
                estadoTimer.subTareaNombre = null;
                ocultarSelectorSubTarea();
            }
            actualizarInfoTarea();
        }

        function actualizarInfoTarea() {
        }

        function cargarSubTareasDeMision(misionId) {
            fetch('/api/v1/pomodoro/mision/' + misionId + '/sub-tareas')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    var select = document.getElementById('subtareaSelect');
                    var container = document.getElementById('subtareaSelector');
                    if (!select || !container) return;
                    select.innerHTML = '<option value="">-- Sin sub-tarea --</option>';
                    if (data && data.datos) {
                        data.datos.forEach(function(st) {
                            var opt = document.createElement('option');
                            opt.value = st.id;
                            opt.textContent = st.nombre + (st.estaCompletada ? ' \u2713' : '');
                            opt.dataset.nombre = st.nombre;
                            select.appendChild(opt);
                        });
                    }
                    container.style.display = 'block';
                })
                .catch(function() {});
        }

        function ocultarSelectorSubTarea() {
            var container = document.getElementById('subtareaSelector');
            if (container) container.style.display = 'none';
        }

        document.addEventListener('change', function(e) {
            if (e.target && e.target.id === 'subtareaSelect') {
                estadoTimer.subTareaId = e.target.value ? parseInt(e.target.value) : null;
                var selectedOpt = e.target.selectedOptions[0];
                estadoTimer.subTareaNombre = selectedOpt ? (selectedOpt.dataset.nombre || selectedOpt.textContent) : null;
                actualizarInfoTarea();
            }
        });

        async function alternarTimer() {
            if (estadoTimer.estaCorriendo) {
                pausarTimer();
            } else {
                await iniciarTimer();
            }
        }

        function actualizarIndicadorDND() {
            var dnd = document.getElementById('dndIndicator');
            if (!dnd) return;
            dnd.style.display = (estadoTimer.estaCorriendo && estadoTimer.modo === 'enfoque') ? 'block' : 'none';
        }

        async function iniciarTimer() {
            try {
                var ctx = obtenerContextoAudio();
                if (ctx.state === 'suspended') { await ctx.resume(); }
            } catch(e) {}

            if ((estadoTimer.modo === 'enfoque' || estadoTimer.modo === 'personalizado') && !estadoTimer.sesionId) {
                let parametrosBody = {};
                if (estadoTimer.tareaSeleccionadaId) {
                    if (estadoTimer.tareaSeleccionadaTipo === 'Habito') parametrosBody.habitoId = estadoTimer.tareaSeleccionadaId;
                    else {
                        parametrosBody.misionId = estadoTimer.tareaSeleccionadaId;
                        if (estadoTimer.subTareaId) parametrosBody.subTareaId = estadoTimer.subTareaId;
                    }
                }
                try {
                    const respuesta = await fetch('/api/v1/pomodoro/iniciar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(parametrosBody)
                    });
                    if (respuesta.ok) {
                        const data = await respuesta.json();
                        estadoTimer.sesionId = data.datos.sesionId;
                        document.getElementById('btnFinalizar').style.display = 'inline-flex';
                    }
                } catch(e) { mostrarError("Error al iniciar sesión. Revisa tu conexión."); }
            }

            estadoTimer.estaCorriendo = true;
            anilloTimer.classList.add('active');
            iconoPlay.classList.replace('bi-play-fill', 'bi-pause-fill');
            textoPlay.innerText = "Pausar";
            iniciarTicTac();
            actualizarIndicadorDND();

            estadoTimer.ultimoTick = Date.now();
            broadcastMensaje('timer_start', { modo: estadoTimer.modo, tiempoRestante: estadoTimer.tiempoRestante, tiempoTotal: estadoTimer.tiempoTotal, ciclos: estadoTimer.ciclosCompletados });
            estadoTimer.idIntervalo = setInterval(() => {
                estadoTimer.ultimoTick = Date.now();
                estadoTimer.tiempoRestante--;
                actualizarUI();

                if (estadoTimer.tiempoRestante <= 0) {
                    alCompletarTimer();
                }
            }, 1000);
        }

        function pausarTimer() {
            estadoTimer.estaCorriendo = false;
            clearInterval(estadoTimer.idIntervalo);
            detenerTicTac();
            anilloTimer.classList.remove('active');
            iconoPlay.classList.replace('bi-pause-fill', 'bi-play-fill');
            textoPlay.innerText = "Continuar";
            actualizarIndicadorDND();
            broadcastMensaje('timer_pause', { modo: estadoTimer.modo, tiempoRestante: estadoTimer.tiempoRestante, tiempoTotal: estadoTimer.tiempoTotal, ciclos: estadoTimer.ciclosCompletados });
        }

        async function detenerTimer() {
            estadoTimer.estaCorriendo = false;
            clearInterval(estadoTimer.idIntervalo);
            detenerTicTac();
            anilloTimer.classList.remove('active');
            iconoPlay.classList.replace('bi-pause-fill', 'bi-play-fill');
            textoPlay.innerText = "Iniciar";

            if (estadoTimer.sesionId) {
                var idSesion = estadoTimer.sesionId;
                estadoTimer.sesionId = null;
                ocultarBotonFinalizar();
                try {
                    const respuesta = await fetch(`/api/v1/pomodoro/${idSesion}/cancelar`, { method: 'POST' });
                    if (!respuesta.ok) {
                        estadoTimer.sesionId = idSesion;
                        mostrarError("Error al cancelar la sesión.");
                    }
                } catch(e) {
                    estadoTimer.sesionId = idSesion;
                    mostrarError("Error de conexión al cancelar la sesión.");
                }
            }
        }

        function reiniciarTimer() {
            if (estadoTimer.estaCorriendo) pausarTimer();
            establecerModo(estadoTimer.modo);
        }

        async function saltarCiclo() {
            if (!confirm("¿Saltar este ciclo? No se otorgará XP.")) return;
            pausarTimer();
            if (estadoTimer.sesionId) {
                var idSesion = estadoTimer.sesionId;
                estadoTimer.sesionId = null;
                try {
                    const respuesta = await fetch(`/api/v1/pomodoro/${idSesion}/cancelar`, { method: 'POST' });
                    if (!respuesta.ok) {
                        estadoTimer.sesionId = idSesion;
                        mostrarError("Error al cancelar el ciclo.");
                        return;
                    }
                } catch(e) {
                    estadoTimer.sesionId = idSesion;
                    mostrarError("Error de conexión al cancelar el ciclo.");
                    return;
                }
            }
            estadoTimer.tiempoRestante = 0;
            ocultarBotonFinalizar();
            establecerModo('corto');
        }

        function ocultarBotonFinalizar() {
            document.getElementById('btnFinalizar').style.display = 'none';
        }

        async function finalizarSesion() {
            if (!estadoTimer.sesionId) return;
            var idSesion = estadoTimer.sesionId;
            ocultarBotonFinalizar();
            if (estadoTimer.estaCorriendo) pausarTimer();
            try {
                const respuesta = await fetch(`/api/v1/pomodoro/${idSesion}/finalizar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ciclosCompletados: estadoTimer.ciclosCompletados })
                });
                        if (respuesta.ok) {
                                    estadoTimer.sesionId = null;
                                    const data = await respuesta.json();
                                    estadoTimer.xpTotal = data.datos.xpTotal;
                                    document.getElementById('statXpGanado').innerText = estadoTimer.xpTotal;
                                    notificar('Sesión finalizada', 'Has ganado ' + data.datos.xpTotal + ' XP (incluyendo ' + data.datos.xpBonus + ' XP bonus).');
                                    mostrarExito('¡Sesión finalizada! ' + data.datos.xpTotal + ' XP ganado (+' + data.datos.xpBonus + ' bonus).');
                                    establecerModo('corto');
                } else {
                    mostrarError("Error al finalizar la sesión.");
                }
            } catch(e) { mostrarError("Error de conexión al finalizar la sesión."); }
        }

        function mostrarAyudaAtajos() {
            var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('modalAtajos'));
            modal.show();
        }

        function alternarPantallaCompleta() {
            var card = document.getElementById('pomodoroCard');
            if (!card) return;
            if (!document.fullscreenElement) {
                card.requestFullscreen().catch(function() { mostrarError("No se pudo activar pantalla completa."); });
            } else {
                document.exitFullscreen().catch(function() { mostrarError("No se pudo salir de pantalla completa."); });
            }
        }

        function actualizarIconoFullscreen() {
            var icon = document.querySelector('#btnFullscreen i');
            if (!icon) return;
            if (document.fullscreenElement) {
                icon.className = 'bi bi-fullscreen-exit';
                document.getElementById('btnFullscreen').title = 'Salir de pantalla completa (F)';
            } else {
                icon.className = 'bi bi-arrows-fullscreen';
                document.getElementById('btnFullscreen').title = 'Pantalla completa (F)';
            }
        }

        document.addEventListener('fullscreenchange', actualizarIconoFullscreen);

        async function alCompletarTimer() {
            // Guarda de reentrancia: el intervalo normal (cada segundo) y la corrección de
            // visibilitychange (al volver de pantalla bloqueada/pestaña oculta) pueden detectar
            // la finalización por separado y llamar a esta función dos veces para el mismo
            // ciclo -> duplicaba el conteo y dejaba el modo a medio cambiar.
            if (estadoTimer.procesandoCompletado) return;
            estadoTimer.procesandoCompletado = true;

            pausarTimer();
            reproducirSonido('completado');
            notificar('Pomodoro', estadoTimer.modo === 'enfoque' ? '¡Ciclo completado! Tómate un descanso.' : '¡Descanso terminado! Vuelve al enfoque.');

            // Si algo dentro falla de forma inesperada (fetch, DOM, modal de Bootstrap que no
            // se muestra en móvil, etc.) sin este try/catch la función se abortaba en silencio
            // dejando tiempoRestante congelado en negativo (ej. "-1:-1") y el modo sin cambiar;
            // al pulsar "Continuar" el intervalo seguía restando desde ahí ("-1:-2", "-1:-3"...).
            try {
            if (estadoTimer.modo === 'enfoque' || estadoTimer.modo === 'personalizado') {
                var prevCiclos = estadoTimer.ciclosCompletados;
                var prevMinutos = estadoTimer.minutosTotales;
                var prevXp = estadoTimer.xpTotal;

                estadoTimer.ciclosCompletados++;
                estadoTimer.minutosTotales += Math.floor((estadoTimer.modo === 'personalizado' ? CONFIGURACION.personalizado : CONFIGURACION.enfoque) / 60);

                document.getElementById('statCiclos').innerText = estadoTimer.ciclosCompletados;
                broadcastMensaje('timer_complete', { ciclos: estadoTimer.ciclosCompletados, xp: estadoTimer.xpTotal });
                document.getElementById('statMinutos').innerText = estadoTimer.minutosTotales;

                if (CONFIGURACION.metaDiaria > 0) {
                    const pct = Math.min(100, (estadoTimer.ciclosCompletados / CONFIGURACION.metaDiaria) * 100);
                    document.getElementById('metaBar').style.width = pct + '%';
                    document.getElementById('metaText').innerText = estadoTimer.ciclosCompletados + ' / ' + CONFIGURACION.metaDiaria;
                    if (estadoTimer.ciclosCompletados >= CONFIGURACION.metaDiaria) {
                        notificar('¡Meta diaria cumplida!', 'Has alcanzado tu meta de ' + CONFIGURACION.metaDiaria + ' ciclos.');
                    }
                }

                agregarHistorial("Enfoque", Math.floor(estadoTimer.tiempoTotal / 60) + " min", true);

                var cicloValido = true;

                if (estadoTimer.sesionId) {
                    try {
                        const respuesta = await fetch(`/api/v1/pomodoro/${estadoTimer.sesionId}/ciclo-completado`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ ciclosCompletados: estadoTimer.ciclosCompletados })
                        });
                        if (respuesta.ok) {
                            const data = await respuesta.json();
                            estadoTimer.xpTotal += data.datos.xpGanado;
                            document.getElementById('statXpGanado').innerText = estadoTimer.xpTotal;
                            actualizarGraficoSemanal();

                            if (data.datos.sugerirDescanso) {
                                notificar('Descanso largo', 'Es momento de un descanso largo. ¡Recupérate!');
                                if (data.datos.pausaActiva) {
                                    document.getElementById('pausaActivaContent').innerHTML = '<i class="bi bi-info-circle me-2"></i>' + data.datos.pausaActiva;
                                    document.getElementById('pausaActivaContent').style.display = 'block';
                                } else {
                                    document.getElementById('pausaActivaContent').style.display = 'none';
                                }
                                document.getElementById('modalDescansoDuracion').innerText = CONFIGURACION.largo / 60;
                                document.getElementById('btnIniciarDescansoLargo').onclick = function() {
                                    window._modalHandled = true;
                                    var modal = bootstrap.Modal.getInstance(document.getElementById('modalDescansoLargo'));
                                    modal.hide();
                                    establecerModo('largo');
                                    alternarTimer();
                                };
                                var modalLargoEl = document.getElementById('modalDescansoLargo');
                                var modalLargo = bootstrap.Modal.getOrCreateInstance(modalLargoEl);
                                if (modalLargoEl._epycusModalHandler) {
                                    modalLargoEl.removeEventListener('hidden.bs.modal', modalLargoEl._epycusModalHandler);
                                }
                                modalLargoEl._epycusModalHandler = function() {
                                    if (!window._modalHandled) {
                                        establecerModo('corto');
                                        if (CONFIGURACION.autoIniciarDescanso) {
                                            setTimeout(function() { alternarTimer(); }, 500);
                                        }
                                    }
                                    window._modalHandled = false;
                                    modalLargoEl.removeEventListener('hidden.bs.modal', modalLargoEl._epycusModalHandler);
                                    delete modalLargoEl._epycusModalHandler;
                                };
                                modalLargoEl.addEventListener('hidden.bs.modal', modalLargoEl._epycusModalHandler);
                                window._modalHandled = false;
                                modalLargo.show();
                                return;
                            }

                            if (data.datos.pausaActiva) {
                                mostrarInfo(data.datos.pausaActiva);
                            }
                        } else {
                            cicloValido = false;
                        }
                    } catch(e) {
                        cicloValido = false;
                        mostrarError("Error al registrar el ciclo. Intenta de nuevo.");
                    }

                    if (!cicloValido) {
                        estadoTimer.ciclosCompletados = prevCiclos;
                        estadoTimer.minutosTotales = prevMinutos;
                        estadoTimer.xpTotal = prevXp;
                        document.getElementById('statCiclos').innerText = prevCiclos;
                        document.getElementById('statMinutos').innerText = prevMinutos;
                        if (CONFIGURACION.metaDiaria > 0) {
                            const pctRollback = Math.min(100, (prevCiclos / CONFIGURACION.metaDiaria) * 100);
                            document.getElementById('metaBar').style.width = pctRollback + '%';
                            document.getElementById('metaText').innerText = prevCiclos + ' / ' + CONFIGURACION.metaDiaria;
                        }
                        var histList = document.getElementById('historialList');
                        if (histList.firstChild && histList.firstChild.classList.contains('position-relative')) {
                            histList.removeChild(histList.firstChild);
                            if (histList.children.length === 0) {
                                histList.innerHTML = '<div class="text-secondary small fst-italic no-sesiones-msg">Aún no hay sesiones registradas hoy.</div>';
                            }
                        }
                        mostrarError("Error al registrar el ciclo. Puedes continuar con el descanso.");
                        establecerModo('corto');
                        if (CONFIGURACION.autoIniciarDescanso) {
                            setTimeout(function() { alternarTimer(); }, 500);
                        }
                        return;
                    }
                }

                if (metaDiariaValue && estadoTimer.ciclosCompletados >= metaDiariaValue) {
                    notificar('Metas', 'Has completado ' + metaDiariaValue + ' ciclos. ¡Buen trabajo!');
                    if (estadoTimer.sesionId) {
                        var idFinalizar = estadoTimer.sesionId;
                        estadoTimer.sesionId = null;
                        ocultarBotonFinalizar();
                        try {
                            var respFin = await fetch(`/api/v1/pomodoro/${idFinalizar}/finalizar`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ ciclosCompletados: estadoTimer.ciclosCompletados })
                            });
                            if (respFin.ok) {
                                var dataFin = await respFin.json();
                                estadoTimer.xpTotal = dataFin.datos.xpTotal;
                                document.getElementById('statXpGanado').innerText = estadoTimer.xpTotal;
                                notificar('Sesión finalizada', 'Has ganado ' + dataFin.datos.xpTotal + ' XP (+' + dataFin.datos.xpBonus + ' bonus).');
                            }
                        } catch(e) { mostrarError("Error al finalizar la sesión automáticamente."); }
                    }
                    if (CONFIGURACION.metaDiaria > 0 && estadoTimer.ciclosCompletados >= CONFIGURACION.metaDiaria) {
                        document.getElementById('modalMetaNumero').innerText = CONFIGURACION.metaDiaria;
                        var modalMeta = bootstrap.Modal.getOrCreateInstance(document.getElementById('modalMetaCumplida'));
                        modalMeta.show();
                        mostrarExito('¡Meta diaria cumplida! Sesión finalizada con XP bonus.');
                    } else {
                        mostrarExito('¡Has completado ' + metaDiariaValue + ' ciclos! Sesión finalizada.');
                    }
                }

                establecerModo('corto');
                if (CONFIGURACION.autoIniciarDescanso) {
                    setTimeout(function() { alternarTimer(); }, 500);
                }

            } else {
                var tipoDescanso = estadoTimer.modo === 'corto' ? 'DescansoCorto' : 'DescansoLargo';
                var segundosDescanso = estadoTimer.tiempoTotal;
                agregarHistorial(estadoTimer.modo === 'corto' ? 'Descanso corto' : 'Descanso largo', Math.floor(estadoTimer.tiempoTotal / 60) + " min", false);
                try {
                    await fetch('/api/v1/pomodoro/descanso', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ tipo: tipoDescanso, segundos: segundosDescanso })
                    });
                } catch(e) { /* fallback silencioso */ }
                establecerModo('enfoque');
                if (CONFIGURACION.autoIniciarEnfoque) {
                    setTimeout(function() { alternarTimer(); }, 500);
                }
            }
            } catch (e) {
                console.error('Error al completar el ciclo de Pomodoro:', e);
                mostrarError('Ocurrió un error al procesar el ciclo. Se reinició el temporizador.');
                var siguienteModo = (estadoTimer.modo === 'enfoque' || estadoTimer.modo === 'personalizado') ? 'corto' : 'enfoque';
                establecerModo(siguienteModo);
            } finally {
                estadoTimer.procesandoCompletado = false;
            }
        }

        function actualizarGraficoSemanal() {
            fetch('/api/v1/pomodoro/racha')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.datos) {
                        var badges = document.querySelectorAll('.badge.bg-warning');
                        if (data.datos.racha > 0) {
                            if (badges.length > 0) {
                                badges.forEach(function(b) { b.innerHTML = '🔥 ' + data.datos.racha + ' día(s)'; });
                            } else {
                                var headerActions = document.querySelector('.mb-4.d-flex.justify-content-between.align-items-center > .d-flex.gap-2');
                                if (headerActions) {
                                    var newBadge = document.createElement('span');
                                    newBadge.className = 'badge bg-warning bg-opacity-25 text-warning border border-warning px-3 py-2';
                                    newBadge.setAttribute('title', 'Racha actual');
                                    newBadge.innerHTML = '🔥 ' + data.datos.racha + ' día(s)';
                                    headerActions.insertBefore(newBadge, headerActions.firstChild);
                                }
                            }
                        } else {
                            if (badges.length > 0) {
                                badges.forEach(function(b) { b.remove(); });
                            }
                        }
                    }
                })
                .catch(function() {});
            fetch('/api/v1/pomodoro/estadisticas-semanales')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.datos && data.datos.length === 7) {
                        var chart = document.getElementById('weeklyChart');
                        if (!chart) return;
                        var maxCiclos = Math.max.apply(null, data.datos.map(function(d) { return d.ciclos; }));
                        if (maxCiclos === 0) maxCiclos = 1;
                        chart.innerHTML = '';
                        data.datos.forEach(function(dia) {
                            var altura = Math.round(dia.ciclos / maxCiclos * 60);
                            var div = document.createElement('div');
                            div.className = 'text-center';
                            div.style.cssText = 'flex:1;';
                            div.innerHTML = '<div class="bg-primary bg-opacity-50 rounded" style="height:' + altura + 'px; width:16px; margin:0 auto; transition: height 0.3s;" title="' + dia.ciclos + ' ciclos"></div><small class="text-secondary" style="font-size:0.6rem;">' + dia.fecha + '</small>';
                            chart.appendChild(div);
                        });
                    }
                })
                .catch(function() {});
        }

        function agregarHistorial(tipo, tiempoTxt, esEnfoque) {
            const histList = document.getElementById('historialList');
            if (histList.querySelector('.no-sesiones-msg')) histList.innerHTML = '';

            const iconClass = esEnfoque ? "bi-check-circle text-success" : "bi-cup-hot text-warning";
            const badgeBg = esEnfoque ? 'var(--success-bg)' : 'var(--warning-bg)';
            const badgeColor = esEnfoque ? 'var(--success)' : 'var(--warning)';
            const badgeBorder = esEnfoque ? 'var(--success)' : 'var(--warning)';
            const badgeText = esEnfoque ? "Completado" : "Descanso";

            const item = document.createElement('div');
            item.className = "position-relative mb-3 ps-4";

            const icon = document.createElement('i');
            icon.className = `bi ${iconClass} position-absolute`;
            icon.style.cssText = "left: -1.35rem; top: 0px; background: var(--ep-superficie); padding-bottom: 5px;";
            item.appendChild(icon);

            const contentDiv = document.createElement('div');
            contentDiv.className = "d-flex justify-content-between align-items-center";
            contentDiv.style.cssText = "font-size: 0.85rem;";

            const textDiv = document.createElement('div');
            const typeSpan = document.createElement('span');
            typeSpan.className = "fw-bold";
            typeSpan.innerText = tipo;
            textDiv.appendChild(typeSpan);
            const timeSpan = document.createElement('span');
            timeSpan.className = "text-secondary ms-2";
            timeSpan.innerText = tiempoTxt;
            textDiv.appendChild(timeSpan);
            contentDiv.appendChild(textDiv);

            const badge = document.createElement('span');
            badge.className = "badge bg-opacity-25";
            badge.style.cssText = `background: ${badgeBg}; color: ${badgeColor}; border: 1px solid ${badgeBorder};`;
            badge.innerText = badgeText;
            contentDiv.appendChild(badge);

            item.appendChild(contentDiv);
            histList.insertBefore(item, histList.firstChild);
        }

        document.addEventListener('keydown', function(e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
            switch(e.key) {
                case ' ':
                    e.preventDefault();
                    alternarTimer();
                    break;
                case 'r':
                case 'R':
                    reiniciarTimer();
                    break;
                case '1':
                    establecerModo('enfoque');
                    break;
                case '2':
                    establecerModo('corto');
                    break;
                case '3':
                    establecerModo('largo');
                    break;
                case '4':
                    establecerModo('personalizado');
                    break;
                case 'f':
                case 'F':
                    alternarPantallaCompleta();
                    break;
                case 's':
                case 'S':
                    if (estadoTimer.modo === 'enfoque' || estadoTimer.modo === 'personalizado') saltarCiclo();
                    break;
            }
        });

        document.addEventListener('visibilitychange', function() {
            if (document.hidden) {
                if (estadoTimer.estaCorriendo) {
                    document.title = formatearTiempo(estadoTimer.tiempoRestante) + ' - Pomodoro';
                    estadoTimer.ultimoTick = Date.now();
                }
            } else {
                document.title = 'Pomodoro - EpycusApp';
                if (estadoTimer.estaCorriendo && estadoTimer.ultimoTick) {
                    var elapsed = Math.max(0, Math.floor((Date.now() - estadoTimer.ultimoTick) / 1000));
                    if (elapsed > 1) {
                        estadoTimer.tiempoRestante = Math.max(0, estadoTimer.tiempoRestante - elapsed);
                        estadoTimer.ultimoTick = Date.now();
                        actualizarUI();
                        if (estadoTimer.tiempoRestante <= 0) {
                            alCompletarTimer();
                        }
                    }
                }
            }
        });

        establecerModo('enfoque');
        actualizarUI();
    </script>
}
