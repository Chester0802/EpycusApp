@model EpycusApp.DTOs.ActualizarConfiguracionPomodoroDto

@{
    ViewData["Title"] = "Configuración Pomodoro";
}

<div class="mb-4">
    <h1 class="ep-header-title d-flex align-items-center gap-2">Configuración Pomodoro <i class="bi bi-sliders text-primary"></i></h1>
    <p class="ep-header-subtitle">Personaliza cada aspecto de tu experiencia Pomodoro.</p>
</div>

<form asp-action="Configuracion" method="post" class="ep-card">
    @Html.AntiForgeryToken()

    @if (TempData["Exito"] is string exito)
    {
        <div class="alert alert-success bg-transparent border-success text-success small">@exito</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger bg-transparent border-danger text-danger small">@error</div>
    }
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <h6 class="fw-bold mb-3"><i class="bi bi-clock me-2"></i>Tiempos</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Estudio (min)</label>
            <input asp-for="TiempoEstudioMin" class="form-range" type="range" min="1" max="180" step="1" oninput="document.getElementById('TiempoEstudioMin_valor').innerText = this.value" />
            <output class="ms-2 fw-bold" id="TiempoEstudioMin_valor">@Model.TiempoEstudioMin</output>
        </div>
        <div class="col-md-4">
            <label class="form-label">Descanso corto (min)</label>
            <input asp-for="TiempoDescansoMin" class="form-range" type="range" min="1" max="60" step="1" oninput="document.getElementById('TiempoDescansoMin_valor').innerText = this.value" />
            <output class="ms-2 fw-bold" id="TiempoDescansoMin_valor">@Model.TiempoDescansoMin</output>
        </div>
        <div class="col-md-4">
            <label class="form-label">Descanso largo (min)</label>
            <input asp-for="TiempoDescansoLargoMin" class="form-range" type="range" min="1" max="120" step="1" oninput="document.getElementById('TiempoDescansoLargoMin_valor').innerText = this.value" />
            <output class="ms-2 fw-bold" id="TiempoDescansoLargoMin_valor">@Model.TiempoDescansoLargoMin</output>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <label class="form-label">Ciclos antes de descanso largo</label>
            <input asp-for="CiclosAntesDescansoLargo" class="form-range" type="range" min="1" max="20" step="1" oninput="document.getElementById('CiclosAntesDescansoLargo_valor').innerText = this.value" />
            <output class="ms-2 fw-bold" id="CiclosAntesDescansoLargo_valor">@Model.CiclosAntesDescansoLargo</output>
        </div>
        <div class="col-md-6">
            <label class="form-label">Modo personalizado (min)</label>
            <input asp-for="ModoPersonalizadoMin" class="form-range" type="range" min="1" max="180" step="1" oninput="document.getElementById('ModoPersonalizadoMin_valor').innerText = this.value" />
            <output class="ms-2 fw-bold" id="ModoPersonalizadoMin_valor">@Model.ModoPersonalizadoMin</output>
        </div>
    </div>

    <hr class="border-secondary opacity-25" />

    <h6 class="fw-bold mb-3"><i class="bi bi-music-note me-2"></i>Sonido</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <label class="form-label">Sonido de notificación</label>
            <div class="d-flex gap-2">
                <select asp-for="SonidoSeleccionado" class="form-select ep-input flex-grow-1">
                    <option value="campana">🔔 Campana suave</option>
                    <option value="digital">🔊 Digital</option>
                    <option value="naturaleza">🌿 Naturaleza</option>
                    <option value="silencio">🔇 Silencio</option>
                </select>
                <button type="button" class="btn btn-sm btn-ep-outline" onclick="previsualizarSonido()" title="Probar sonido">▶</button>
            </div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Volumen</label>
            <input asp-for="Volumen" class="form-range" type="range" min="0" max="100" step="5" oninput="document.getElementById('Volumen_valor').innerText = this.value + '%'" />
            <output class="ms-2 fw-bold" id="Volumen_valor">@Model.Volumen%</output>
        </div>
        <div class="col-md-4 d-flex align-items-end pb-2">
            <div class="form-check">
                <input asp-for="TicTacActivo" class="form-check-input" />
                <label asp-for="TicTacActivo" class="form-check-label">Reloj tic-tac durante enfoque</label>
            </div>
        </div>
    </div>

    <hr class="border-secondary opacity-25" />

    <h6 class="fw-bold mb-3"><i class="bi bi-arrow-repeat me-2"></i>Auto-inicio</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="form-check">
                <input asp-for="AutoIniciarDescanso" class="form-check-input" />
                <label asp-for="AutoIniciarDescanso" class="form-check-label">Iniciar descanso automáticamente tras cada ciclo</label>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-check">
                <input asp-for="AutoIniciarEnfoque" class="form-check-input" />
                <label asp-for="AutoIniciarEnfoque" class="form-check-label">Iniciar enfoque automáticamente tras descanso</label>
            </div>
        </div>
    </div>

    <hr class="border-secondary opacity-25" />

    <h6 class="fw-bold mb-3"><i class="bi bi-flag me-2"></i>Metas</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <label class="form-label">Meta diaria de ciclos (0 = sin meta)</label>
            <input asp-for="MetaDiariaCiclos" class="form-range" type="range" min="0" max="50" step="1" oninput="document.getElementById('MetaDiariaCiclos_valor').innerText = this.value" />
            <output class="ms-2 fw-bold" id="MetaDiariaCiclos_valor">@Model.MetaDiariaCiclos</output>
        </div>
    </div>

    <hr class="border-secondary opacity-25" />

    <h6 class="fw-bold mb-3"><i class="bi bi-phone me-2"></i>Notificaciones</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="form-check">
                <input asp-for="SonidoActivo" class="form-check-input" />
                <label asp-for="SonidoActivo" class="form-check-label">Sonido al completar ciclo</label>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-check">
                <input asp-for="VibracionActiva" class="form-check-input" />
                <label asp-for="VibracionActiva" class="form-check-label">Vibración (móvil)</label>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-check">
                <input asp-for="NotificacionDesktop" class="form-check-input" />
                <label asp-for="NotificacionDesktop" class="form-check-label">Notificación de escritorio</label>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-ep">Guardar cambios</button>
        <a asp-action="Index" class="btn btn-ep-outline">Volver</a>
    </div>
</form>

@section Scripts {
    <script>
        function previsualizarSonido() {
            var sonido = document.getElementById('SonidoSeleccionado').value;
            if (sonido === 'silencio') return;
            try {
                var ctx = new (window.AudioContext || window.webkitAudioContext)();
                var gain = ctx.createGain();
                gain.connect(ctx.destination);
                gain.gain.value = 0.3;
                if (sonido === 'campana') {
                    var osc = ctx.createOscillator();
                    osc.type = 'sine';
                    osc.frequency.value = 523.25;
                    osc.connect(gain);
                    osc.start();
                    osc.stop(ctx.currentTime + 0.3);
                } else if (sonido === 'digital') {
                    var osc = ctx.createOscillator();
                    osc.type = 'square';
                    osc.frequency.value = 880;
                    osc.connect(gain);
                    osc.start();
                    osc.stop(ctx.currentTime + 0.15);
                } else if (sonido === 'naturaleza') {
                    var bufferSize = ctx.sampleRate * 0.5;
                    var buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
                    var data = buffer.getChannelData(0);
                    for (var i = 0; i < bufferSize; i++) {
                        data[i] = (Math.random() * 2 - 1) * (1 - i / bufferSize);
                    }
                    var noise = ctx.createBufferSource();
                    noise.buffer = buffer;
                    noise.connect(gain);
                    noise.start();
                }
            } catch(e) {}
        }
    </script>
}
