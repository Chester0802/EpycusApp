@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="ep-card">
    <div class="d-flex align-items-center gap-3 mb-3">
        <i class="bi bi-exclamation-triangle text-danger fs-1"></i>
        <div>
            <h1 class="h3 fw-bold mb-1">Ocurrió un error</h1>
            <p class="text-muted mb-0">Algo no salió como esperábamos. Intenta nuevamente en unos minutos.</p>
        </div>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="text-muted small">ID de solicitud: <code>@Model.RequestId</code></div>
    }

    <div class="ep-separador"></div>
    <a asp-controller="Home" asp-action="Index" class="btn btn-ep">Volver al inicio</a>
</div>
