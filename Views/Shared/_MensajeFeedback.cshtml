@if (TempData["Exito"] != null)
{
    <div class="ep-alerta ep-alerta-exito mb-4" role="alert">
        <i class="bi bi-check-circle-fill ep-alerta-icono" style="color: var(--success);"></i>
        <div>
            <div class="ep-alerta-titulo">Acción completada</div>
            <div style="color: var(--text-secondary);">@TempData["Exito"]</div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ep-alerta ep-alerta-error mb-4" style="border-left-color: var(--error);" role="alert">
        <i class="bi bi-exclamation-triangle-fill ep-alerta-icono" style="color: var(--error);"></i>
        <div>
            <div class="ep-alerta-titulo" style="color: var(--error);">Ocurrió un problema</div>
            <div style="color: var(--text-secondary);">@TempData["Error"]</div>
        </div>
    </div>
}
