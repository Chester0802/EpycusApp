<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Epycus</title>
    <link rel="stylesheet" href="~/lib/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/epycus-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/temas/tema-noche-epica.css" id="hoja-tema" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script>
        (function() {
            var temaGuardado = localStorage.getItem('epycus_theme') || 'oscuro';
            var hojaTema = document.getElementById('hoja-tema');
            if (temaGuardado === 'claro') {
                hojaTema.href = '/css/temas/tema-sakura.css';
                document.documentElement.setAttribute('data-theme', 'light');
            } else {
                hojaTema.href = '/css/temas/tema-noche-epica.css';
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="auth-page">
        <div class="auth-container">
            <div class="auth-hero-side">
                <img src="~/login-hero.webp" alt="Epycus" class="auth-hero-img" />
                <div class="auth-hero-overlay">
                    <div class="auth-hero-content">
                        <img src="~/img/logo.webp" alt="Epycus" class="auth-hero-logo" onerror="this.style.display='none'" />
                        <h2 class="auth-hero-title">Epycus</h2>
                        <p class="auth-hero-subtitle">Tu progreso profesional en un solo lugar.</p>
                    </div>
                </div>
            </div>
            <div class="auth-form-side">
                <div class="auth-form-inner">
                    <div class="d-flex justify-content-end mb-3">
                        <button id="btn-toggle-tema" class="btn btn-sm btn-ep-outline d-flex align-items-center gap-2" type="button">
                            <span><i class="bi bi-moon-stars"></i> Modo Oscuro</span>
                            <div class="form-check form-switch m-0 p-0 d-flex align-items-center">
                                <input class="form-check-input ms-0" type="checkbox" role="switch" id="switch-tema" style="cursor: pointer; width: 2.5em; height: 1.25em;">
                            </div>
                        </button>
                    </div>
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme-manager.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
