<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Epycus</title>
    <link rel="stylesheet" href="~/lib/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/epycus-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/temas/tema-noche-epica.css" id="hoja-tema" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script>
        (function() {
            var temaGuardado = localStorage.getItem('epycus_theme') || 'oscuro';
            var hojaTema = document.getElementById('hoja-tema');
            if (temaGuardado === 'claro') {
                hojaTema.href = '/css/temas/tema-sakura.css';
            } else {
                hojaTema.href = '/css/temas/tema-noche-epica.css';
            }
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex min-vh-100 align-items-center justify-content-center" style="background: var(--ep-fondo);">
        <main class="w-100 position-relative" style="max-width: 480px;">
            <div class="d-flex justify-content-end mb-3">
                <button id="btn-toggle-tema-login" class="btn btn-sm btn-ep-outline d-flex align-items-center gap-2" type="button">
                    <span id="texto-tema-login"><i class="bi bi-moon-stars"></i> Modo Oscuro</span>
                    <div class="form-check form-switch m-0 p-0 d-flex align-items-center">
                        <input class="form-check-input ms-0" type="checkbox" role="switch" id="switch-tema-login" style="cursor: pointer; width: 2.5em; height: 1.25em;">
                    </div>
                </button>
            </div>
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; border-radius: 16px; background: var(--ep-superficie-2); color: var(--ep-primario);">
                    <i class="bi bi-stars"></i>
                </div>
                <h1 class="h4 fw-bold mb-1">Epycus</h1>
                <p class="text-muted small mb-0">Tu progreso profesional en un solo lugar.</p>
            </div>
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var switchTema = document.getElementById('switch-tema-login');
            var botonTema = document.getElementById('btn-toggle-tema-login');
            var textoTema = document.getElementById('texto-tema-login');
            var hojaTema = document.getElementById('hoja-tema');

            if (!switchTema || !botonTema || !textoTema || !hojaTema) {
                return;
            }

            var temaGuardado = localStorage.getItem('epycus_theme') || 'oscuro';
            if (temaGuardado === 'oscuro') {
                switchTema.checked = true;
                textoTema.innerHTML = '<i class="bi bi-moon-stars"></i> Modo Oscuro';
            } else {
                switchTema.checked = false;
                textoTema.innerHTML = '<i class="bi bi-sun"></i> Modo Claro';
            }

            switchTema.addEventListener('change', alternarTema);
            botonTema.addEventListener('click', function(e) {
                if (e.target !== switchTema) {
                    switchTema.checked = !switchTema.checked;
                    alternarTema();
                }
            });

            function alternarTema() {
                if (switchTema.checked) {
                    localStorage.setItem('epycus_theme', 'oscuro');
                    hojaTema.href = '/css/temas/tema-noche-epica.css';
                    textoTema.innerHTML = '<i class="bi bi-moon-stars"></i> Modo Oscuro';
                } else {
                    localStorage.setItem('epycus_theme', 'claro');
                    hojaTema.href = '/css/temas/tema-sakura.css';
                    textoTema.innerHTML = '<i class="bi bi-sun"></i> Modo Claro';
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
