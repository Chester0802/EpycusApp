<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Epycus</title>
    <link rel="stylesheet" href="~/lib/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/epycus-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/temas/tema-noche-epica.css" id="hoja-tema" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        <button id="ep-sidebar-toggle-admin" class="btn d-md-none position-fixed" style="top: 0.75rem; left: 0.75rem; z-index: 1060; background: var(--accent-primary); color: var(--text-on-accent, #fff); border-radius: var(--radius-md); padding: 0.5rem 0.65rem; font-size: 1.1rem;">
            <i class="bi bi-list"></i>
        </button>
        <aside class="ep-sidebar ep-sidebar-admin" id="ep-sidebar-admin">
            <div class="d-flex align-items-center gap-2 mb-4">
                <img src="~/img/logo.webp" alt="Epycus" style="width: 28px; height: 28px; object-fit: contain;" onerror="this.style.display='none'" />
                <i class="bi bi-shield-lock fs-4"></i>
                <span class="fw-semibold">Panel Admin</span>
            </div>
            <div class="ep-card mb-3 p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="ep-boton-icono"><i class="bi bi-lightning"></i></div>
                    <div>
                        <div class="small text-muted">Estado del sistema</div>
                        <div class="fw-semibold">Operativo</div>
                    </div>
                </div>
            </div>
            <div class="ep-card mb-4 p-3">
                <div class="small text-muted">Acciones rápidas</div>
                <div class="d-flex gap-2 mt-2">
                    <a asp-controller="Admin" asp-action="Usuarios" class="btn btn-ep-outline btn-sm flex-grow-1">Usuarios</a>
                    <a asp-controller="Admin" asp-action="Frases" class="btn btn-ep btn-sm flex-grow-1">Frases</a>
                </div>
            </div>
            <nav class="d-flex flex-column gap-2">
                <a asp-controller="Admin" asp-action="Index" class="ep-nav-item"><i class="bi bi-speedometer2"></i>Dashboard</a>
                <a asp-controller="Admin" asp-action="Usuarios" class="ep-nav-item"><i class="bi bi-people"></i>Usuarios</a>
                <a asp-controller="Admin" asp-action="Frases" class="ep-nav-item"><i class="bi bi-chat-quote"></i>Frases</a>
                <a asp-controller="Admin" asp-action="Index" class="ep-nav-item"><i class="bi bi-award"></i>Logros</a>
                <a asp-controller="Admin" asp-action="Index" class="ep-nav-item"><i class="bi bi-gear"></i>Configuración</a>
            </nav>
            <form asp-controller="Admin" asp-action="Logout" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn w-100 text-start ep-nav-item text-danger" style="background: transparent; border: none;">
                    <i class="bi bi-box-arrow-right text-danger"></i> Cerrar sesión
                </button>
            </form>
        </aside>
        <main class="ep-contenido flex-grow-1">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toggleBtn = document.getElementById('ep-sidebar-toggle-admin');
            var sidebar = document.getElementById('ep-sidebar-admin');
            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', function() {
                    sidebar.classList.toggle('open');
                    var icon = toggleBtn.querySelector('i');
                    icon.className = sidebar.classList.contains('open') ? 'bi bi-x-lg' : 'bi bi-list';
                });
                document.addEventListener('click', function(e) {
                    if (window.innerWidth < 768 && sidebar.classList.contains('open') &&
                        !sidebar.contains(e.target) && e.target !== toggleBtn && !toggleBtn.contains(e.target)) {
                        sidebar.classList.remove('open');
                        toggleBtn.querySelector('i').className = 'bi bi-list';
                    }
                });
            }
        });
    </script>
    <script src="~/lib/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
