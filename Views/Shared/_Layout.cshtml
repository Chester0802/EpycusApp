<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Epycus</title>
    <link rel="stylesheet" href="~/lib/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/epycus-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/perfil.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ia.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notificaciones.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/temas/tema-noche-epica.css" id="hoja-tema" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script src="~/js/theme-manager.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex">
        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        }
        <aside class="ep-sidebar">
            <div class="d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-stars fs-4"></i>
                <span class="fw-semibold">Epycus</span>
            </div>
            <nav class="d-flex flex-column gap-2 mb-auto">
                <a asp-controller="Home" asp-action="Index" class="ep-nav-item@(currentController == "Home" ? " activo" : "")"><i class="bi bi-house"></i>Inicio</a>
                <a asp-controller="Habitos" asp-action="Index" class="ep-nav-item@(currentController == "Habitos" ? " activo" : "")"><i class="bi bi-list-check"></i>HÃ¡bitos</a>
                <a asp-controller="Misiones" asp-action="Index" class="ep-nav-item@(currentController == "Misiones" ? " activo" : "")"><i class="bi bi-clipboard-check"></i>Misiones</a>
                <a asp-controller="Pomodoro" asp-action="Index" class="ep-nav-item@(currentController == "Pomodoro" ? " activo" : "")"><i class="bi bi-alarm"></i>Pomodoro</a>
                <a asp-controller="Progreso" asp-action="Index" class="ep-nav-item@(currentController == "Progreso" ? " activo" : "")"><i class="bi bi-graph-up"></i>Progreso</a>
                <a asp-controller="Ajustes" asp-action="Index" class="ep-nav-item@(currentController == "Ajustes" ? " activo" : "")"><i class="bi bi-gear"></i>Ajustes</a>
            </nav>
            <div class="mt-4 pt-3 border-top" style="border-color: rgba(128,128,128,0.2) !important;">
                <button id="btn-toggle-tema" class="btn w-100 text-start ep-nav-item d-flex justify-content-between align-items-center" style="background: transparent; border: none; padding: 0.75rem 1rem;">
                    <span><i class="bi bi-moon-stars"></i> Modo Oscuro</span>
                    <div class="form-check form-switch m-0 p-0 d-flex align-items-center">
                        <input class="form-check-input ms-0 me-0" type="checkbox" role="switch" id="switch-tema" style="cursor: pointer; width: 2.5em; height: 1.25em;">
                    </div>
                </button>
                <div class="text-muted small mt-2">Usa el switch para cambiar el tema.</div>
                @if(User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Autenticacion" asp-action="Logout" method="post" class="mt-2">
                        <button type="submit" class="btn w-100 text-start ep-nav-item text-danger" style="background: transparent; border: none;">
                            <i class="bi bi-box-arrow-right text-danger"></i>Cerrar SesiÃ³n
                        </button>
                    </form>
                }
            </div>
        </aside>
        <main class="ep-contenido flex-grow-1">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Exponer si el usuario estÃ¡ autenticado al cliente
        window.isAuthenticated = @(User.Identity != null && User.Identity.IsAuthenticated ? "true" : "false");
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
